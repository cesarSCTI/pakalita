{% comment %}
  Section: Testimonials
  - Cada reseña es un bloque del editor
  - Carrusel flex: avanza/retrocede 1 testimonio a la vez
  - Visible N testimonios a la vez (configurable)
{% endcomment %}

{%- liquid
  assign visible = section.settings.visible_count
  assign title = section.settings.title
-%}

<section
  class="testimonials-section"
  id="testimonials-{{ section.id }}"
  style="
    --ts-bg: {{ section.settings.section_bg }};
    --ts-gap: {{ section.settings.gap }}px;
    --ts-visible: {{ visible }};
    --ts-padding-top: {{ section.settings.padding_top }}px;
    --ts-padding-bottom: {{ section.settings.padding_bottom }}px;
    --ts-title-color: {{ section.settings.title_color }};
    --ts-text-color: {{ section.settings.text_color }};
    --ts-meta-color: {{ section.settings.meta_color }};
    --ts-arrow-bg: {{ section.settings.arrow_bg }};
    --ts-arrow-color: {{ section.settings.arrow_color }};
    --ts-arrow-radius: {{ section.settings.arrow_radius }}px;
    --ts-quote-size: {{ section.settings.quote_size }}px;
    --ts-divider-color: {{ section.settings.divider_color }};
    --ts-card-bg: {{ section.settings.card_bg }};
    --ts-card-radius: {{ section.settings.card_radius }}px;
    --ts-card-padding: {{ section.settings.card_padding }}px;
  "
>
  <div class="testimonials__inner page-width">

    {%- if title != blank -%}
      <h2 class="testimonials__heading">{{ title }}</h2>
    {%- endif -%}

    <div class="testimonials__carousel-wrap">

      {%- comment %} Flecha anterior {%- endcomment %}
      <button
        class="testimonials__arrow testimonials__arrow--prev"
        aria-label="Testimonio anterior"
        type="button"
        data-ts-prev="{{ section.id }}"
        disabled
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      {%- comment %} Viewport: recorta el overflow {%- endcomment %}
      <div class="testimonials__viewport" id="ts-viewport-{{ section.id }}">
        <div
          class="testimonials__track"
          id="ts-track-{{ section.id }}"
          role="list"
        >
          {%- for block in section.blocks -%}
            <div
              class="testimonials__card"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              {%- comment %} Cita {%- endcomment %}
              {%- if block.settings.quote != blank -%}
                <blockquote class="testimonials__quote">
                  <span class="testimonials__quote-mark">&ldquo;</span>{{ block.settings.quote }}<span class="testimonials__quote-mark">&rdquo;</span>
                </blockquote>
              {%- endif -%}

              {%- comment %} Estrellas {%- endcomment %}
              {%- if section.settings.show_stars and block.settings.rating > 0 -%}
                <div class="testimonials__stars" aria-label="{{ block.settings.rating }} de 5 estrellas">
                  {%- for i in (1..5) -%}
                    <svg class="testimonials__star{% if i <= block.settings.rating %} testimonials__star--filled{% endif %}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  {%- endfor -%}
                </div>
              {%- endif -%}
              {%- comment %} Meta: nombre + fecha {%- endcomment %}
              <div class="testimonials__meta">
                <span class="testimonials__author">{{ block.settings.author | default: 'Anónimo' }}</span>
                {%- if block.settings.date != blank -%}
                  <span class="testimonials__date">{{ block.settings.date }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- else -%}
            {%- comment %} Placeholder {%- endcomment %}
            {%- for i in (1..3) -%}
              <div class="testimonials__card">
                <blockquote class="testimonials__quote">
                  <span class="testimonials__quote-mark">&ldquo;</span>Este es un ejemplo de reseña. Puedes agregar tus propias reseñas desde el editor de secciones.<span class="testimonials__quote-mark">&rdquo;</span>
                </blockquote>
                <div class="testimonials__meta">
                  <span class="testimonials__author">Nombre del cliente</span>
                  <span class="testimonials__date">1 Jan 2025</span>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

      {%- comment %} Flecha siguiente {%- endcomment %}
      <button
        class="testimonials__arrow testimonials__arrow--next"
        aria-label="Siguiente testimonio"
        type="button"
        data-ts-next="{{ section.id }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

    </div>

    {%- comment %} Dots {%- endcomment %}
    <div class="testimonials__dots" id="ts-dots-{{ section.id }}" aria-hidden="true"></div>

  </div>
</section>

{% stylesheet %}

/* =====================================================
   SECTION
   ===================================================== */
.testimonials-section {
  max-width: var(--container-v2);
  margin: auto;
  background: var(--ts-bg);
  padding-top: var(--ts-padding-top);
  padding-bottom: var(--ts-padding-bottom);
}

.testimonials__heading {
  text-align: center;
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 400;
  color: var(--ts-title-color);
  margin: 0 0 2rem;
  letter-spacing: -0.01em;
}

/* =====================================================
   CAROUSEL WRAP — flex row: flecha | viewport | flecha
   ===================================================== */
.testimonials__carousel-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 1rem;
  max-width: 70%;
  margin: auto;
}

/* =====================================================
   VIEWPORT
   ===================================================== */
.testimonials__viewport {
  flex: 1;
  overflow: hidden;
  min-width: 0;
}

/* =====================================================
   TRACK — flex puro, transform-based
   ===================================================== */
.testimonials__track {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--ts-gap);
  will-change: transform;
  transition: transform 0.42s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* =====================================================
   CARD
   Ancho = (100% - gaps_entre_visibles) / visibles
   ===================================================== */
.testimonials__card {
  flex: 0 0 calc(
    (100% - (var(--ts-visible) - 1) * var(--ts-gap)) / var(--ts-visible)
  );
  min-width: 0;
  background: var(--ts-card-bg);
  border-radius: var(--ts-card-radius);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
}

/* =====================================================
   QUOTE
   ===================================================== */
.testimonials__quote {
  margin: 0;
  font-size: var(--ts-quote-size);
  line-height: 1.65;
  color: var(--ts-text-color);
  font-style: normal;
  font-weight: 400;
  font-family: "Poppins", sans-serif;
}

.testimonials__quote-mark {
  font-style: normal;
  color: var(--ts-text-color);
}

/* =====================================================
   STARS
   ===================================================== */
.testimonials__stars {
  display: flex;
  gap: 2px;
}

.testimonials__star {
  width: 14px;
  height: 14px;
  color: #d8cfc8;
}

.testimonials__star--filled {
  color: #c07a50;
}

/* =====================================================
   META — flex row, nombre izq / fecha der
   ===================================================== */
.testimonials__meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.testimonials__author {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--ts-meta-color);
}

.testimonials__date {
  font-size: 0.82rem;
  color: var(--ts-meta-color);
  opacity: 0.65;
}

/* =====================================================
   FLECHAS
   ===================================================== */
.testimonials__arrow {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  border-radius: var(--ts-arrow-radius);
  background: var(--ts-arrow-bg);
  border: 1px solid color-mix(in srgb, var(--ts-arrow-color) 20%, transparent);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ts-arrow-color);
  padding: 0;
  transition: opacity 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
}

.testimonials__arrow svg {
  width: 18px;
  height: 18px;
}

.testimonials__arrow:hover:not(:disabled) {
  box-shadow: 0 3px 12px rgba(0,0,0,0.12);
  transform: scale(1.06);
}

.testimonials__arrow:disabled {
  opacity: 0.25;
  cursor: default;
  transform: none;
}

/* =====================================================
   DOTS
   ===================================================== */
.testimonials__dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 1.25rem;
}

.testimonials__dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #d0cdc9;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  flex-shrink: 0;
}

.testimonials__dot.is-active {
  background: var(--ts-arrow-color);
  transform: scale(1.35);
}

/* =====================================================
   RESPONSIVE — móvil: 1 visible, flechas más pequeñas
   ===================================================== */
@media screen and (max-width: 680px) {
  .testimonials__card {
    flex: 0 0 100%;
  }

  .testimonials__arrow {
    width: 34px;
    height: 34px;
  }

  .testimonials__arrow svg {
    width: 15px;
    height: 15px;
  }

  .testimonials__carousel-wrap {
    gap: 0.5rem;
  }
}

@media (prefers-reduced-motion: reduce) {
  .testimonials__track { transition: none; }
  .testimonials__arrow { transition: none; }
}

{% endstylesheet %}

<script>
(function () {
  const sid      = '{{ section.id }}';
  const viewport = document.getElementById('ts-viewport-' + sid);
  const track    = document.getElementById('ts-track-' + sid);
  const dotsWrap = document.getElementById('ts-dots-' + sid);
  const btnPrev  = document.querySelector('[data-ts-prev="' + sid + '"]');
  const btnNext  = document.querySelector('[data-ts-next="' + sid + '"]');

  if (!track || !viewport) return;

  const cards = Array.from(track.children);
  let current = 0; /* índice del primer card visible */

  /* ─── Cuántos cards son visibles según CSS variable ─── */
  function visibleCount() {
    if (window.innerWidth <= 680) return 1;
    return parseInt(
      getComputedStyle(track.closest('.testimonials-section'))
        .getPropertyValue('--ts-visible')
    ) || 1;
  }

  /* ─── Total de posiciones posibles ─── */
  function maxIndex() {
    return Math.max(0, cards.length - visibleCount());
  }

  /* ─── Mover track con transform ─── */
  function goTo(index) {
    index   = Math.max(0, Math.min(index, maxIndex()));
    current = index;

    const gap   = parseFloat(getComputedStyle(track).gap) || 0;
    const cardW = cards[0] ? cards[0].offsetWidth : 0;
    track.style.transform = 'translateX(-' + (index * (cardW + gap)) + 'px)';

    if (btnPrev) btnPrev.disabled = current === 0;
    if (btnNext) btnNext.disabled = current >= maxIndex();

    /* Dots */
    dotsWrap.querySelectorAll('.testimonials__dot')
      .forEach((d, i) => d.classList.toggle('is-active', i === current));
  }

  /* ─── Construir dots ─── */
  function buildDots() {
    dotsWrap.innerHTML = '';
    const total = maxIndex() + 1;
    if (total <= 1) return;
    for (let i = 0; i <= maxIndex(); i++) {
      const dot = document.createElement('button');
      dot.className = 'testimonials__dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('aria-label', 'Ir al testimonio ' + (i + 1));
      dot.addEventListener('click', () => goTo(i));
      dotsWrap.appendChild(dot);
    }
  }

  /* ─── Swipe táctil ─── */
  let touchStartX = 0;
  viewport.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  viewport.addEventListener('touchend', e => {
    const delta = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(delta) > 40) goTo(delta > 0 ? current + 1 : current - 1);
  }, { passive: true });

  /* ─── Botones: avanzan/retroceden de 1 en 1 ─── */
  if (btnPrev) btnPrev.addEventListener('click', () => goTo(current - 1));
  if (btnNext) btnNext.addEventListener('click', () => goTo(current + 1));

  /* ─── Init / Resize ─── */
  function init() {
    current = 0;
    track.style.transform = 'translateX(0)';
    buildDots();
    if (btnPrev) btnPrev.disabled = true;
    if (btnNext) btnNext.disabled = maxIndex() === 0;
  }

  init();

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(init, 120);
  });

})();
</script>

{% schema %}
{
  "name": "V2 Testimonials",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Reseñas"
    },
    {
      "type": "range",
      "id": "visible_count",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Testimonios visibles a la vez (desktop)",
      "default": 1
    },
    {
      "type": "range",
      "id": "gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Espacio entre testimonios",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Mostrar calificación con estrellas",
      "default": false
    },
    {
      "type": "header",
      "content": "Tarjeta de testimonio"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fondo de la tarjeta",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Redondez de esquinas",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding interno de la tarjeta",
      "default": 0
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto de la reseña",
      "default": "#222222"
    },
    {
      "type": "range",
      "id": "quote_size",
      "min": 13,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamaño del texto de la reseña",
      "default": 16
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Color del nombre y la fecha",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Color del divisor",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Flechas de navegación"
    },
    {
      "type": "color",
      "id": "arrow_bg",
      "label": "Fondo de la flecha",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Color del ícono",
      "default": "#7A4A3A"
    },
    {
      "type": "range",
      "id": "arrow_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Redondez de la flecha",
      "default": 50
    },
    {
      "type": "header",
      "content": "Sección"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Fondo de la sección",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Reseña",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Texto de la reseña",
          "default": "This kombucha is absolutely refreshing! The perfect balance of sweetness and tanginess makes it my go-to drink every day."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Nombre del cliente",
          "default": "Victor Herms"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Fecha",
          "default": "2 Jan 2025"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "label": "Calificación (estrellas)",
          "default": 5,
          "info": "0 = sin calificación"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "V2 Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
