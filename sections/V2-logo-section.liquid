{% comment %}
  Section: Logo Carousel
  - Cada logo es un bloque con imagen + link opcional
  - Columnas configurables por dispositivo (desktop/tablet/móvil)
  - Full width o container width
  - Modos: grid | auto (cinta infinita) | manual (prev/next)
{% endcomment %}

<section
  class="logo-carousel"
  id="logo-carousel-{{ section.id }}"
  data-mode="{{ section.settings.carousel_mode }}"
  data-speed="{{ section.settings.auto_speed }}"
  data-section-id="{{ section.id }}"
  style="
    --lc-bg: {{ section.settings.bg_color }};
    --lc-cols-desktop: {{ section.settings.cols_desktop }};
    --lc-cols-tablet: {{ section.settings.cols_tablet }};
    --lc-cols-mobile: {{ section.settings.cols_mobile }};
    --lc-gap: {{ section.settings.gap }}px;
    --lc-logo-opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
    --lc-logo-opacity-hover: {{ section.settings.logo_opacity_hover | divided_by: 100.0 }};
    --lc-padding-top: {{ section.settings.padding_top }}px;
    --lc-padding-bottom: {{ section.settings.padding_bottom }}px;
    --lc-title-color: {{ section.settings.title_color }};
    --lc-divider-color: {{ section.settings.divider_color }};
    --lc-filter: {% if section.settings.grayscale %}grayscale(1){% else %}grayscale(0){% endif %};
    --lc-auto-speed: {{ section.settings.auto_speed }}s;
  "
>
  <div class="logo-carousel__wrap{% if section.settings.full_width %} logo-carousel__wrap--full{% else %} page-width{% endif %}">

    {%- if section.settings.title != blank -%}
      <h2 class="logo-carousel__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.show_divider_top -%}
      <div class="logo-carousel__divider" aria-hidden="true"></div>
    {%- endif -%}

    {%- comment %} Controles prev/next — solo visibles en modo manual {%- endcomment %}
    <div class="logo-carousel__outer">

      <button
        class="logo-carousel__btn logo-carousel__btn--prev"
        id="lc-prev-{{ section.id }}"
        aria-label="Anterior"
        type="button"
        hidden
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      {%- comment %} VIEWPORT {%- endcomment %}
      <div class="logo-carousel__viewport" id="lc-viewport-{{ section.id }}">
        <div
          class="logo-carousel__track"
          id="lc-track-{{ section.id }}"
          role="list"
          aria-label="Logos de clientes"
        >
          {%- for block in section.blocks -%}
            <div
              class="logo-carousel__item"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.image != blank -%}
                {%- if block.settings.link != blank -%}
                  <a
                    href="{{ block.settings.link }}"
                    class="logo-carousel__link"
                    aria-label="{{ block.settings.alt_text | default: block.settings.image.alt | default: 'Logo cliente' }}"
                    {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                  >
                    {{
                      block.settings.image
                      | image_url: height: block.settings.logo_height
                      | image_tag:
                        loading: 'lazy',
                        widths: '120, 200, 300, 400, 600',
                        sizes: '200px',
                        class: 'logo-carousel__image',
                        alt: block.settings.alt_text | default: block.settings.image.alt | default: 'Logo'
                    }}
                  </a>
                {%- else -%}
                  {{
                    block.settings.image
                    | image_url: height: block.settings.logo_height
                    | image_tag:
                      loading: 'lazy',
                      widths: '120, 200, 300, 400, 600',
                      sizes: '200px',
                      class: 'logo-carousel__image',
                      alt: block.settings.alt_text | default: block.settings.image.alt | default: 'Logo'
                  }}
                {%- endif -%}
              {%- else -%}
                <div class="logo-carousel__placeholder">Logo</div>
              {%- endif -%}
            </div>
          {%- else -%}
            {%- for i in (1..4) -%}
              <div class="logo-carousel__item">
                <div class="logo-carousel__placeholder">BRAND {{ i }}</div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

      <button
        class="logo-carousel__btn logo-carousel__btn--next"
        id="lc-next-{{ section.id }}"
        aria-label="Siguiente"
        type="button"
        hidden
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    {%- if section.settings.show_divider_bottom -%}
      <div class="logo-carousel__divider" aria-hidden="true"></div>
    {%- endif -%}

  </div>
</section>

<style>

/* =====================================================
   SECTION
   ===================================================== */
.logo-carousel {
  background: var(--lc-bg);
  padding-top: var(--lc-padding-top);
  padding-bottom: var(--lc-padding-bottom);
}

.logo-carousel__wrap--full {
  width: 100%;
  padding-left: 2rem;
  padding-right: 2rem;
  box-sizing: border-box;
}

/* =====================================================
   TÍTULO
   ===================================================== */
.logo-carousel__title {
  text-align: center;
  font-size: {{ section.settings.font_size_Desktop }}px;
  font-weight: 400;
  font-style: italic;
  color: var(--lc-title-color);
  margin: 0 0 40px;
  letter-spacing: -0.01em;
  font-family: "Platypi", serif !important;
  line-height: 1.2 !important;
}

/* =====================================================
   DIVISOR
   ===================================================== */
.logo-carousel__divider {
  height: 1px;
  background: var(--lc-divider-color);
  opacity: 0.12;
  margin: 1rem 0;
}

/* =====================================================
   OUTER — contiene botones + viewport
   ===================================================== */
.logo-carousel__outer {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  position: relative;
}

/* =====================================================
   BOTONES PREV / NEXT
   ===================================================== */
.logo-carousel__btn {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1.5px solid currentColor;
  background: transparent;
  color: var(--lc-title-color);
  cursor: pointer;
  opacity: 0.55;
  transition: opacity 0.2s ease, background 0.2s ease;
  z-index: 2;
  padding: 0;
}

.logo-carousel__btn:hover {
  opacity: 1;
  background: color-mix(in srgb, var(--lc-title-color) 8%, transparent);
}

.logo-carousel__btn:disabled {
  opacity: 0.2;
  cursor: default;
}

/* =====================================================
   VIEWPORT
   ===================================================== */
.logo-carousel__viewport {
  overflow: hidden;
  width: 100%;
  flex: 1 1 0%;
}

/* =====================================================
   TRACK — base: grid wrapping
   ===================================================== */
.logo-carousel__track {
  display: flex;
  flex-wrap: wrap;
  gap: var(--lc-gap);
  align-items: center;
  justify-content: center;
  will-change: transform;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* =====================================================
   MODO AUTO — cinta infinita
   ===================================================== */
.logo-carousel[data-mode="auto"] .logo-carousel__track {
  flex-wrap: nowrap;
  justify-content: flex-start;
  width: max-content;
  animation: lc-scroll var(--lc-auto-speed) linear infinite;
}

.logo-carousel[data-mode="auto"] .logo-carousel__track:hover,
.logo-carousel[data-mode="auto"] .logo-carousel__track:focus-within {
  animation-play-state: paused;
}

@keyframes lc-scroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(var(--lc-clone-width, -50%)); }
}

.logo-carousel[data-mode="auto"] .logo-carousel__item {
  flex: 0 0 auto;
}

/* =====================================================
   MODO MANUAL — sin wrap, JS mueve el track
   ===================================================== */
.logo-carousel[data-mode="manual"] .logo-carousel__track {
  flex-wrap: nowrap;
  justify-content: flex-start;
  transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.logo-carousel[data-mode="manual"] .logo-carousel__item {
  flex: 0 0 calc(
    (100% - (var(--lc-cols-desktop) - 1) * var(--lc-gap)) / var(--lc-cols-desktop)
  );
  flex-shrink: 0;
}

/* =====================================================
   ITEM — modo grid (default)
   ===================================================== */
.logo-carousel[data-mode="grid"] .logo-carousel__item,
.logo-carousel__item {
  flex: 0 0 calc(
    (100% - (var(--lc-cols-desktop) - 1) * var(--lc-gap)) / var(--lc-cols-desktop)
  );
  display: flex;
  align-items: center;
  justify-content: center;
}

/* =====================================================
   IMAGEN
   ===================================================== */
.logo-carousel__image {
  display: block;
  width: 100%;
  max-width: 100%;
  object-fit: contain;
  object-position: center;
  filter: var(--lc-filter);
  opacity: var(--lc-logo-opacity);
  transition: opacity 0.25s ease, filter 0.25s ease;
}

.logo-carousel__link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.logo-carousel__link:hover .logo-carousel__image,
.logo-carousel__item:not(:has(a)):hover .logo-carousel__image {
  opacity: var(--lc-logo-opacity-hover);
  filter: grayscale(0);
}

.logo-carousel__placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56px;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: var(--lc-title-color);
  opacity: 0.3;
  text-transform: uppercase;
  width: 100%;
}

/* =====================================================
   TABLET
   ===================================================== */
@media screen and (max-width: 900px) {
  .logo-carousel[data-mode="grid"] .logo-carousel__item,
  .logo-carousel__item {
    flex: 0 0 calc(
      (100% - (var(--lc-cols-tablet) - 1) * var(--lc-gap)) / var(--lc-cols-tablet)
    );
  }

  .logo-carousel[data-mode="manual"] .logo-carousel__item {
    flex: 0 0 calc(
      (100% - (var(--lc-cols-tablet) - 1) * var(--lc-gap)) / var(--lc-cols-tablet)
    );
  }
}

/* =====================================================
   MÓVIL
   ===================================================== */
@media screen and (max-width: 600px) {
  .logo-carousel__title {
    font-size: {{ section.settings.font_size_Mobile }}px;
  }

  /* Grid → scroll nativo en móvil */
  .logo-carousel[data-mode="grid"] .logo-carousel__track {
    flex-wrap: nowrap;
    justify-content: flex-start;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }

  .logo-carousel[data-mode="grid"] .logo-carousel__track::-webkit-scrollbar { display: none; }

  .logo-carousel[data-mode="grid"] .logo-carousel__item,
  .logo-carousel__item {
    flex: 0 0 calc(
      (100% - (var(--lc-cols-mobile) - 1) * var(--lc-gap)) / var(--lc-cols-mobile)
    );
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  .logo-carousel[data-mode="manual"] .logo-carousel__item {
    flex: 0 0 calc(
      (100% - (var(--lc-cols-mobile) - 1) * var(--lc-gap)) / var(--lc-cols-mobile)
    );
  }

  .logo-carousel__wrap--full {
    padding-left: 1rem;
    padding-right: 1rem;
  }
}

/* =====================================================
   REDUCED MOTION
   ===================================================== */
@media (prefers-reduced-motion: reduce) {
  .logo-carousel__image { transition: none; }
  .logo-carousel[data-mode="auto"] .logo-carousel__track {
    animation: none !important;
  }
  .logo-carousel[data-mode="manual"] .logo-carousel__track {
    transition: none;
  }
}

</style>

<script>
(function () {
  'use strict';

  function initLogoCarousel(section) {
    const mode    = section.dataset.mode;
    const id      = section.dataset.sectionId;
    const track   = document.getElementById('lc-track-' + id);
    const vp      = document.getElementById('lc-viewport-' + id);
    const btnPrev = document.getElementById('lc-prev-' + id);
    const btnNext = document.getElementById('lc-next-' + id);

    if (!track || !vp) return;

    /* ------------------------------------------------
       MODO AUTO — cinta infinita
    ------------------------------------------------ */
    if (mode === 'auto') {
      /* Duplicamos los items para el loop continuo */
      const origItems = Array.from(track.children);
      origItems.forEach(function (item) {
        const clone = item.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        clone.removeAttribute('role');
        track.appendChild(clone);
      });

      /* Calculamos el ancho del set original para la animación */
      function setCloneWidth() {
        const gap = parseFloat(getComputedStyle(track).gap) || 0;
        let w = 0;
        origItems.forEach(function (item) { w += item.offsetWidth + gap; });
        /* Expresamos como px negativo para translateX */
        section.style.setProperty('--lc-clone-width', '-' + w + 'px');
      }

      setCloneWidth();
      window.addEventListener('resize', setCloneWidth);
      return; /* no necesita botones */
    }

    /* ------------------------------------------------
       MODO MANUAL — prev / next
    ------------------------------------------------ */
    if (mode === 'manual') {
      btnPrev.hidden = false;
      btnNext.hidden = false;

      let currentIndex = 0;

      function getVisibleCols() {
        const vpWidth = vp.offsetWidth;
        if (vpWidth <= 600) return parseInt(section.style.getPropertyValue('--lc-cols-mobile')) || 2;
        if (vpWidth <= 900) return parseInt(section.style.getPropertyValue('--lc-cols-tablet')) || 3;
        return parseInt(section.style.getPropertyValue('--lc-cols-desktop')) || 4;
      }

      function getItemWidth() {
        const first = track.querySelector('.logo-carousel__item');
        if (!first) return 0;
        const gap = parseFloat(getComputedStyle(track).gap) || 0;
        return first.offsetWidth + gap;
      }

      function totalItems() {
        return track.querySelectorAll('.logo-carousel__item').length;
      }

      function maxIndex() {
        return Math.max(0, totalItems() - getVisibleCols());
      }

      function goTo(index) {
        currentIndex = Math.max(0, Math.min(index, maxIndex()));
        const offset = currentIndex * getItemWidth();
        track.style.transform = 'translateX(-' + offset + 'px)';
        btnPrev.disabled = currentIndex === 0;
        btnNext.disabled = currentIndex >= maxIndex();
      }

      btnPrev.addEventListener('click', function () { goTo(currentIndex - getVisibleCols()); });
      btnNext.addEventListener('click', function () { goTo(currentIndex + getVisibleCols()); });

      /* Recalcular al redimensionar */
      let resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () { goTo(currentIndex); }, 100);
      });

      goTo(0);
      return;
    }

    /* ------------------------------------------------
       MODO GRID — nada que hacer en JS
    ------------------------------------------------ */
  }

  /* Inicialización */
  function init() {
    document.querySelectorAll('.logo-carousel').forEach(function (section) {
      initLogoCarousel(section);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  /* Soporte Shopify Theme Editor (re-init al cambiar settings) */
  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', function (e) {
      const section = e.target.querySelector('.logo-carousel');
      if (section) initLogoCarousel(section);
    });
  }
})();
</script>

{% schema %}
{
  "name": "V2 Logo Carousel",
  "tag": "section",
  "class": "section",
  "max_blocks": 16,
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Nuestros clientes"
    },
    {
      "type": "range",
      "id": "font_size_Desktop",
      "label": "Font size desktop",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "range",
      "id": "font_size_Mobile",
      "label": "Font size mobile",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "header",
      "content": "Modo de visualización"
    },
    {
      "type": "select",
      "id": "carousel_mode",
      "label": "Modo de carrusel",
      "options": [
        { "value": "grid",   "label": "Grid (filas y columnas)" },
        { "value": "auto",   "label": "Auto-scroll (cinta infinita)" },
        { "value": "manual", "label": "Manual (botones prev / next)" }
      ],
      "default": "grid",
      "info": "En modo Grid, el móvil usa scroll horizontal automáticamente."
    },
    {
      "type": "range",
      "id": "auto_speed",
      "label": "Velocidad del auto-scroll (segundos por ciclo)",
      "min": 5,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 20,
      "info": "Solo aplica en modo Auto-scroll. Menor número = más rápido."
    },
    {
      "type": "header",
      "content": "Ancho"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Ancho completo (full width)",
      "default": false,
      "info": "Si está desactivado usa el contenedor estándar (page-width)"
    },
    {
      "type": "header",
      "content": "Columnas por dispositivo"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Logos por fila — Desktop (>900px)",
      "default": 4
    },
    {
      "type": "range",
      "id": "cols_tablet",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Logos por fila — Tablet (601–900px)",
      "default": 3
    },
    {
      "type": "range",
      "id": "cols_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Logos visibles — Móvil (≤600px)",
      "default": 2
    },
    {
      "type": "header",
      "content": "Logos"
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacidad normal",
      "default": 60
    },
    {
      "type": "range",
      "id": "logo_opacity_hover",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacidad al hacer hover",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Mostrar logos en escala de grises",
      "default": false
    },
    {
      "type": "header",
      "content": "Divisores"
    },
    {
      "type": "checkbox",
      "id": "show_divider_top",
      "label": "Línea divisora superior",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_divider_bottom",
      "label": "Línea divisora inferior",
      "default": false
    },
    {
      "type": "header",
      "content": "Colores y espaciado"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de la sección",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Color del divisor",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espacio entre logos",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen del logo"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Texto alternativo (alt)",
          "info": "Describe la empresa para accesibilidad"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link del logo (opcional)"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Abrir en nueva pestaña",
          "default": true
        },
        {
          "type": "range",
          "id": "logo_height",
          "min": 24,
          "max": 120,
          "step": 4,
          "unit": "px",
          "label": "Altura de los logos",
          "default": 56
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "V2 Logo Carousel",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
