      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "toolbar_text_color",
      "label": "Color del texto del toolbar",
      "default": "#111111"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Mostrar filtros de Search & Discovery",
      "default": true,
      "info": "Requiere la app Search & Discovery de Shopify configurada"
    },
    {
      "type": "checkbox",
      "id": "show_view_toggle",
      "label": "Mostrar toggle de vista (grid/lista)",
      "default": true
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Mensaje cuando no hay productos",
      "default": "No se encontraron productos."
    },
    {
      "type": "header",
      "content": "Paginación"
    },
    {
      "type": "color",
      "id": "pagination_active_color",
      "label": "Color de página activa",
      "default": "#A0522D"
    },
    {
      "type": "color",
      "id": "pagination_text_color",
      "label": "Color del texto de paginación",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Sección"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Fondo de la sección",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "V2 CollectionFilter"
    }
  ]
}
{% endschema %}
