{% comment %}
  Section: Related Products
  - Va en templates/product.json
  - Muestra productos de la misma colección o recomendados por Shopify
  - Mismo look de cards que V2 Featured Collection
  - Carrusel flex + transform
{% endcomment %}

{%- liquid
  assign columns_desktop = section.settings.columns_desktop
  assign products_to_show = section.settings.products_to_show
  assign add_to_cart_label = section.settings.add_to_cart_label | default: 'AGREGAR AL CARRITO'
  assign add_to_cart_label_options = section.settings.add_to_cart_label_options | default: 'VER TODAS LAS OPCIONES'

  comment
    Fuente de productos: recomendaciones de Shopify o misma colección
  endcomment
  assign use_recommendations = section.settings.product_source
-%}

<section
  class="related-products-section"
  id="related-products-{{ section.id }}"
  style="
    --rp-columns: {{ columns_desktop }};
    --rp-gap: {{ section.settings.gap }}px;
    --rp-radius: {{ section.settings.card_radius }}px;
    --rp-btn-bg: {{ section.settings.btn_bg_color }};
    --rp-btn-text: {{ section.settings.btn_text_color }};
    --rp-btn-radius: {{ section.settings.btn_radius }}px;
    --rp-add-bg: {{ section.settings.add_bg_color }};
    --rp-add-text: {{ section.settings.add_text_color }};
    --rp-nav-color: {{ section.settings.nav_color }};
    --rp-section-bg: {{ section.settings.section_bg }};
    --rp-title-color: {{ section.settings.title_color }};
    --rp-padding-top: {{ section.settings.padding_top }}px;
    --rp-padding-bottom: {{ section.settings.padding_bottom }}px;
    --rp-card-bg: {{ section.settings.card_bg }};
    --rp-price-color: {{ section.settings.price_color }};
    --rp-product-title-color: {{ section.settings.product_title_color }};
  "
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <div class="related-products__inner page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="related-products__heading">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- comment %} ── CASO 1: Recomendaciones de Shopify (AJAX) ── {%- endcomment %}
    {%- if use_recommendations == 'recommendations' -%}

      <div
        class="related-products__recommendations-wrap"
        id="rp-recommendations-{{ section.id }}"
        data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ products_to_show }}"
      >
        {%- comment %} Placeholder mientras carga {%- endcomment %}
        <div class="related-products__skeleton">
          {%- for i in (1..columns_desktop) -%}
            <div class="rp-skeleton__card">
              <div class="rp-skeleton__image"></div>
              <div class="rp-skeleton__info">
                <div class="rp-skeleton__line rp-skeleton__line--title"></div>
                <div class="rp-skeleton__line rp-skeleton__line--price"></div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

    {%- comment %} ── CASO 2: Misma colección del producto ── {%- endcomment %}
    {%- elsif use_recommendations == 'collection' -%}

      {%- assign current_collection = product.collections.first -%}
      {%- assign related_limit = products_to_show | plus: 1 -%}

      {%- comment %} Viewport + Track {%- endcomment %}
      <div class="related-products__viewport" id="rp-viewport-{{ section.id }}">
        <div
          class="related-products__track"
          id="rp-track-{{ section.id }}"
          role="list"
        >
          {%- if current_collection != blank -%}
            {%- assign count = 0 -%}
            {%- for p in current_collection.products limit: related_limit -%}
              {%- unless p.id == product.id -%}
                {%- if count < products_to_show -%}
                  {%- assign count = count | plus: 1 -%}
                  {%- render 'rp-card',
                    product: p,
                    add_to_cart_label: add_to_cart_label,
                    add_to_cart_label_options: add_to_cart_label_options,
                    show_wishlist: section.settings.show_wishlist,
                    show_add_to_cart: section.settings.show_add_to_cart
                  -%}
                {%- endif -%}
              {%- endunless -%}
            {%- else -%}
              {%- for i in (1..columns_desktop) -%}
                <div class="related-products__card">
                  <div class="rp-card__image-wrap">
                    <div class="rp-card__placeholder">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
                  </div>
                  <div class="rp-card__info">
                    <h3 class="rp-card__title">Producto 0{{ i }}</h3>
                    <div class="rp-card__price"><span>$0.00</span></div>
                  </div>
                </div>
              {%- endfor -%}
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..columns_desktop) -%}
              <div class="related-products__card">
                <div class="rp-card__image-wrap">
                  <div class="rp-card__placeholder">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
                </div>
                <div class="rp-card__info">
                  <h3 class="rp-card__title">Producto 0{{ i }}</h3>
                  <div class="rp-card__price"><span>$0.00</span></div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      {%- comment %} Controles {%- endcomment %}
      <div class="related-products__controls">
        <button class="related-products__arrow related-products__arrow--prev" aria-label="Anterior" type="button" data-rp-prev="{{ section.id }}" disabled>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="related-products__dots" id="rp-dots-{{ section.id }}" aria-hidden="true"></div>
        <button class="related-products__arrow related-products__arrow--next" aria-label="Siguiente" type="button" data-rp-next="{{ section.id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

    {%- endif -%}

    {%- comment %} Ver todos {%- endcomment %}
    {%- if section.settings.show_view_all -%}
      {%- assign view_url = product.collections.first.url | default: routes.all_products_collection_url -%}
      <div class="related-products__footer">
        <a href="{{ view_url }}" class="related-products__view-all">
          {{ section.settings.view_all_label | default: 'Ver todos' }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{%- comment %}
  Snippet inline para el modo colección.
  En modo recomendaciones el HTML de las cards se inyecta via AJAX
  desde la respuesta del endpoint product_recommendations_url.
{%- endcomment %}

{% stylesheet %}

/* =====================================================
   SECTION BASE
   ===================================================== */
.related-products-section {
  background: var(--rp-section-bg);
  padding-top: var(--rp-padding-top);
  padding-bottom: var(--rp-padding-bottom);
}

.related-products__heading {
  text-align: center;
  font-style: italic;
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  color: var(--rp-title-color);
  margin: 0 0 1.75rem;
  font-family: "Platypi", serif !important;
  line-height:1.3;
}

/* =====================================================
   SKELETON LOADER (mientras carga recomendaciones)
   ===================================================== */
.related-products__skeleton {
  display: flex;
  gap: var(--rp-gap);
}

.rp-skeleton__card {
  flex: 0 0 calc(
    (100% - (var(--rp-columns) - 1) * var(--rp-gap)) / var(--rp-columns)
  );
  border-radius: var(--rp-radius);
  overflow: hidden;
}

.rp-skeleton__image {
  aspect-ratio: 1 / 1;
  background: linear-gradient(90deg, #f0ece6 25%, #e8e4de 50%, #f0ece6 75%);
  background-size: 200% 100%;
  animation: rp-shimmer 1.4s infinite;
}

.rp-skeleton__info {
  padding: 20px;
  border: solid 1px #ececec;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.rp-skeleton__line {
  height: 12px;
  border-radius: 6px;
  background: linear-gradient(90deg, #f0ece6 25%, #e8e4de 50%, #f0ece6 75%);
  background-size: 200% 100%;
  animation: rp-shimmer 1.4s infinite;
}

.rp-skeleton__line--title { width: 70%; }
.rp-skeleton__line--price { width: 40%; }

@keyframes rp-shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* =====================================================
   VIEWPORT
   ===================================================== */
.related-products__viewport,
.related-products__recommendations-wrap {
  overflow: hidden;
  width: 100%;
}

/* =====================================================
   TRACK
   ===================================================== */
.related-products__track {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--rp-gap);
  will-change: transform;
  transition: transform 0.42s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* =====================================================
   CARD — mismo diseño que V2 Featured Collection
   ===================================================== */
.related-products__card {
  flex: 0 0 calc(
    (100% - (var(--rp-columns) - 1) * var(--rp-gap)) / var(--rp-columns)
  );
  min-width: 0;
  background: var(--rp-card-bg);
  border-radius: var(--rp-radius);
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  transition: box-shadow 0.3s ease;
}

.related-products__card:hover {
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

/* ---- Imagen ---- */
.rp-card__image-wrap {
  position: relative;
  overflow: hidden;
  background: #f5f3f0;
  aspect-ratio: 1 / 1;
}

.rp-card__image-link {
  display: block;
  width: 100%;
  height: 100%;
}

.rp-card__image {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: opacity 0.4s ease;
}

.rp-card__image--hover {
  position: absolute;
  inset: 0;
  opacity: 0;
}

.rp-card__image-link:hover .rp-card__image:not(.rp-card__image--hover) { opacity: 0; }
.rp-card__image-link:hover .rp-card__image--hover { opacity: 1; }

.rp-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0ece6;
}

.rp-card__placeholder .placeholder-svg {
  width: 55%;
  height: 55%;
  opacity: 0.3;
}

/* ---- Wishlist ---- */
.rp-card__wishlist {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 1px 6px rgba(0,0,0,0.12);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  z-index: 2;
  padding: 0;
}

.rp-card__wishlist:hover { transform: scale(1.12); box-shadow: 0 3px 10px rgba(0,0,0,0.18); }
.rp-card__wishlist.is-active svg { fill: #c0392b; color: #c0392b; stroke: #c0392b; }
.rp-card__wishlist svg { width: 16px; height: 16px; color: #333; }

/* ---- Badge ---- */
.rp-card__badge {
  position: absolute;
  top: 10px;
  left: 10px;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 4px;
  z-index: 2;
  line-height: 1.4;
}

.rp-card__badge--sale { background: #c0392b; color: #fff; }

/* ---- Add to cart (hover) ---- */
.rp-card__add-form,
.rp-card__add-btn--link {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 3;
}

.rp-card__add-btn {
  display: block;
  width: 90%;
  margin: auto;
  padding: 0.75rem 1rem;
  background: var(--rp-add-bg);
  color: var(--rp-add-text);
  border: none;
  cursor: pointer;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-align: center;
  text-decoration: none;
  line-height: 1;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  font-family: Poppins, sans-serif;
}

.rp-card__add-btn--link {
  display: block;
  padding: 0.75rem 1rem;
  background: var(--rp-add-bg);
  color: var(--rp-add-text);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-align: center;
  text-decoration: none;
  line-height: 1;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  font-family: Poppins, sans-serif;
}

.rp-card__image-wrap:hover .rp-card__add-btn,
.rp-card__image-wrap:hover .rp-card__add-btn--link {
  transform: translateY(-20px);
}

/* ---- Info ---- */
.rp-card__info {
  padding: 20px;
  border: solid 1px #ececec;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.rp-card__title-link { text-decoration: none; color: inherit; }

.rp-card__title {
  font-size: 20px;
  font-weight: 600;
  margin: 0 0 0.3rem;
  color: var(--rp-product-title-color);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: "Poppins", sans-serif;
}

.rp-card__price {
  font-size: 0.9rem;
  color: var(--rp-price-color);
  display: flex;
  gap: 0.5rem;
  align-items: baseline;
  font-family: "Poppins", sans-serif;
}

.rp-card__price--compare { color: #999; font-weight: 400; }
.rp-card__price--sale    { color: #c0392b; font-weight: 600; }

/* =====================================================
   CONTROLES
   ===================================================== */
.related-products__controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-top: 1.4rem;
}

.related-products__arrow {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #fff;
  border: 1px solid #e0ddd8;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--rp-nav-color);
  padding: 0;
  transition: box-shadow 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
}

.related-products__arrow svg { width: 16px; height: 16px; }

.related-products__arrow:hover:not(:disabled) {
  box-shadow: 0 4px 16px rgba(0,0,0,0.14);
  transform: scale(1.07);
}

.related-products__arrow:disabled {
  opacity: 0.28;
  cursor: default;
}

.related-products__dots {
  display: flex;
  align-items: center;
  gap: 6px;
}

.related-products__dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #d0cdc9;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  flex-shrink: 0;
}

.related-products__dot.is-active {
  background: var(--rp-nav-color);
  transform: scale(1.35);
}

/* =====================================================
   VER TODOS
   ===================================================== */
.related-products__footer {
  display: flex;
  justify-content: center;
  margin-top: 2rem;
}

.related-products__view-all {
  display: inline-block;
  padding: 0.7em 2.2em;
  background: var(--rp-btn-bg);
  color: var(--rp-btn-text);
  border-radius: var(--rp-btn-radius);
  text-decoration: none;
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.related-products__view-all:hover {
  opacity: 0.85;
  transform: translateY(-1px);
}
.related-products__inner.page-width{
    padding:0px 20px;
}
/* =====================================================
   RESPONSIVE
   ===================================================== */
@media screen and (max-width: 600px) {
  .related-products__card,
  .rp-skeleton__card {
    flex: 0 0 78vw;
    max-width: 300px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .related-products__track { transition: none; }
  .rp-card__add-btn,
  .rp-card__add-btn--link,
  .rp-card__image { transition: none; }
  .rp-skeleton__image,
  .rp-skeleton__line { animation: none; }
}

{% endstylesheet %}

<script>
(function () {
  const sid = '{{ section.id }}';
  const source = '{{ section.settings.product_source }}';

  /* ─────────────────────────────────────────────────────
     MODO RECOMENDACIONES — carga AJAX del endpoint Shopify
  ───────────────────────────────────────────────────── */
  if (source === 'recommendations') {
    const wrap = document.getElementById('rp-recommendations-' + sid);
    if (!wrap) return;

    const url = wrap.dataset.url;

    fetch(url)
      .then(res => res.text())
      .then(html => {
        const parser = new DOMParser();
        const doc    = parser.parseFromString(html, 'text/html');

        /* El endpoint devuelve la section completa — extraemos el track y controles */
        const newViewport = doc.querySelector('.related-products__viewport');
        const newControls = doc.querySelector('.related-products__controls');

        if (newViewport) {
          /* Reemplazamos el skeleton por el viewport real */
          wrap.innerHTML = '';
          wrap.classList.remove('related-products__recommendations-wrap');
          wrap.classList.add('related-products__viewport');
          wrap.id = 'rp-viewport-' + sid;
          wrap.innerHTML = newViewport.innerHTML;

          /* Inyectamos los controles después del wrap */
          if (newControls) {
            wrap.insertAdjacentElement('afterend', newControls);
          }

          /* Iniciamos el carrusel con el nuevo contenido */
          initCarousel(sid);
        } else {
          /* Sin recomendaciones — ocultar sección */
          const section = document.getElementById('related-products-' + sid);
          if (section) section.style.display = 'none';
        }
      })
      .catch(() => {
        /* Error de red — ocultar skeleton */
        const skeleton = wrap.querySelector('.related-products__skeleton');
        if (skeleton) skeleton.style.display = 'none';
      });

    return;
  }

  /* ─────────────────────────────────────────────────────
     MODO COLECCIÓN — carrusel ya está en el DOM
  ───────────────────────────────────────────────────── */
  initCarousel(sid);

  /* ─────────────────────────────────────────────────────
     FUNCIÓN CARRUSEL
  ───────────────────────────────────────────────────── */
  function initCarousel(id) {
    const viewport = document.getElementById('rp-viewport-' + id);
    const track    = document.getElementById('rp-track-' + id);
    const dotsWrap = document.getElementById('rp-dots-' + id);
    const btnPrev  = document.querySelector('[data-rp-prev="' + id + '"]');
    const btnNext  = document.querySelector('[data-rp-next="' + id + '"]');

    if (!track || !viewport) return;

    const cards = Array.from(track.children);
    let current  = 0;

    function visibleCount() {
      const section = track.closest('.related-products-section');
      const cols = parseInt(
        getComputedStyle(section).getPropertyValue('--rp-columns')
      ) || 3;
      return window.innerWidth <= 600 ? 1 : cols;
    }

    function totalPages() {
      return Math.max(1, Math.ceil(cards.length / visibleCount()));
    }

    function goTo(page) {
      const pages = totalPages();
      page    = Math.max(0, Math.min(page, pages - 1));
      current = page;

      const cols  = visibleCount();
      const gap   = parseFloat(getComputedStyle(track).gap) || 0;
      const cardW = cards[0] ? cards[0].offsetWidth : 0;
      track.style.transform = 'translateX(-' + (page * cols * (cardW + gap)) + 'px)';

      if (btnPrev) btnPrev.disabled = current === 0;
      if (btnNext) btnNext.disabled = current >= pages - 1;

      if (dotsWrap) {
        dotsWrap.querySelectorAll('.related-products__dot')
          .forEach((d, i) => d.classList.toggle('is-active', i === current));
      }
    }

    function buildDots() {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      const pages = totalPages();
      if (pages <= 1) return;
      for (let i = 0; i < pages; i++) {
        const dot = document.createElement('button');
        dot.className = 'related-products__dot' + (i === 0 ? ' is-active' : '');
        dot.setAttribute('aria-label', 'Página ' + (i + 1));
        dot.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(dot);
      }
    }

    /* Swipe táctil */
    let touchStartX = 0;
    viewport.addEventListener('touchstart', e => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });

    viewport.addEventListener('touchend', e => {
      const delta = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(delta) > 40) goTo(delta > 0 ? current + 1 : current - 1);
    }, { passive: true });

    if (btnPrev) btnPrev.addEventListener('click', () => goTo(current - 1));
    if (btnNext) btnNext.addEventListener('click', () => goTo(current + 1));

    /* Wishlist */
    track.querySelectorAll('[data-rp-wishlist]').forEach(btn => {
      btn.addEventListener('click', () => btn.classList.toggle('is-active'));
    });

    function init() {
      current = 0;
      track.style.transform = 'translateX(0)';
      buildDots();
      if (btnPrev) btnPrev.disabled = true;
      if (btnNext) btnNext.disabled = totalPages() <= 1;
    }

    init();

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(init, 120);
    });
  }

})();
</script>

{% schema %}
{
  "name": "V2 Related Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "También te puede gustar"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Fuente de productos",
      "options": [
        {
          "value": "recommendations",
          "label": "Recomendaciones de Shopify (automático)"
        },
        {
          "value": "collection",
          "label": "Misma colección del producto"
        }
      ],
      "default": "recommendations",
      "info": "Las recomendaciones de Shopify usan IA para sugerir productos relacionados. La opción 'Misma colección' muestra productos de la primera colección asignada al producto."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Número de productos a mostrar",
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Cards visibles a la vez (desktop)",
