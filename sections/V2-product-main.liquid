{% comment %}
  Section: Product Main
  - Galería con thumbnails verticales + imagen principal
  - Variantes nativas de Shopify (colores como swatches, tallas/otras como pills)
  - Selector de cantidad
  - Agregar al carrito (AJAX)
  - Trust badges configurables
  - Flexbox 100%
  - Template: templates/product.json
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_media = current_variant.featured_media | default: product.featured_media
  assign product_form_id = 'product-form-' | append: section.id
-%}

<div
  class="product-main"
  id="product-main-{{ section.id }}"
  style="
    --pm-gap: {{ section.settings.col_gap }}px;
    --pm-thumb-width: {{ section.settings.thumb_width }}px;
    --pm-thumb-gap: {{ section.settings.thumb_gap }}px;
    --pm-btn-bg: {{ section.settings.btn_bg }};
    --pm-btn-text: {{ section.settings.btn_text }};
    --pm-btn-radius: {{ section.settings.btn_radius }}px;
    --pm-swatch-size: {{ section.settings.swatch_size }}px;
    --pm-pill-radius: {{ section.settings.pill_radius }}px;
    --pm-accent: {{ section.settings.accent_color }};
    --pm-title-color: {{ section.settings.title_color }};
    --pm-price-color: {{ section.settings.price_color }};
    --pm-text-color: {{ section.settings.text_color }};
    --pm-meta-color: {{ section.settings.meta_color }};
    --pm-border-color: {{ section.settings.border_color }};
    --pm-section-bg: {{ section.settings.section_bg }};
    --pm-padding-top: {{ section.settings.padding_top }}px;
    --pm-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pm-image-radius: {{ section.settings.image_radius }}px;
    --pm-qty-bg: {{ section.settings.qty_bg }};
    --pm-qty-text: {{ section.settings.qty_text }};
  "
>
  <div class="product-main__inner page-width" style="padding:0px 20px;">
    <div class="product-main__layout">

      {%- comment %} ══════════════════════════════════════
        COLUMNA IZQUIERDA: GALERÍA
      ══════════════════════════════════════ {%- endcomment %}
      <div class="product-main__gallery">

        {%- comment %} Thumbnails verticales {%- endcomment %}
        <div class="product-main__thumbs" id="pm-thumbs-{{ section.id }}" role="list">
          {%- for media in product.media -%}
            <button
              class="product-main__thumb{% if media == featured_media %} is-active{% endif %}"
              data-media-id="{{ media.id }}"
              data-pm-thumb="{{ section.id }}"
              aria-label="Ver imagen {{ forloop.index }}"
              type="button"
              role="listitem"
            >
              {{
                media.preview_image
                | image_url: width: 200
                | image_tag:
                  loading: 'lazy',
                  widths: '100, 150, 200',
                  class: 'product-main__thumb-img',
                  alt: media.alt | default: product.title
              }}
            </button>
          {%- endfor -%}
        </div>

        {%- comment %} Imagen principal {%- endcomment %}
        <div class="product-main__media-wrap" id="pm-media-{{ section.id }}">
          {%- for media in product.media -%}
            <div
              class="product-main__media{% if media == featured_media %} is-active{% endif %}"
              data-media-id="{{ media.id }}"
              id="pm-media-item-{{ section.id }}-{{ media.id }}"
            >
              {%- if media.media_type == 'image' -%}
                {{
                  media
                  | image_url: width: 1200
                  | image_tag:
                    loading: forloop.first | ternary: 'eager', 'lazy',
                    fetchpriority: forloop.first | ternary: 'high', 'low',
                    widths: '400, 600, 800, 1000, 1200',
                    sizes: '(max-width: 768px) 100vw, 55vw',
                    class: 'product-main__image',
                    alt: media.alt | default: product.title
                }}
              {%- elsif media.media_type == 'video' -%}
                {{ media | video_tag: class: 'product-main__image', autoplay: false, controls: true, muted: false }}
              {%- elsif media.media_type == 'model' -%}
                {{ media | model_viewer_tag: class: 'product-main__image', reveal: 'interaction', ar: true, ar-modes: 'webxr scene-viewer quick-look' }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

      </div>

      {%- comment %} ══════════════════════════════════════
        COLUMNA DERECHA: INFO + FORMULARIO
      ══════════════════════════════════════ {%- endcomment %}
      <div class="product-main__info">

        {%- comment %} Cabecera: colección + acciones {%- endcomment %}
        <div class="product-main__header">
          <div class="product-main__header-left">
            {%- if section.settings.show_vendor and product.vendor != blank -%}
              <p class="product-main__vendor">{{ product.vendor }}</p>
            {%- endif -%}
            {%- for collection in product.collections limit: 1 -%}
              <a href="{{ collection.url }}" class="product-main__collection-link">{{ collection.title | upcase }}</a>
            {%- endfor -%}
          </div>
          <div class="product-main__header-actions">
            {%- if section.settings.show_share -%}
              <button class="product-main__action-btn" data-share aria-label="Compartir" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              </button>
            {%- endif -%}
            {%- if section.settings.show_wishlist -%}
              <button class="product-main__action-btn" data-wishlist="{{ product.id }}" aria-label="Guardar" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>
            {%- endif -%}
          </div>
        </div>

        {%- comment %} Título {%- endcomment %}
        <h1 class="product-main__title">{{ product.title }}</h1>

        {%- comment %} Estrellas (decorativas, reemplazables con app de reviews) {%- endcomment %}
        {%- if section.settings.show_stars -%}
          <div class="product-main__stars" aria-label="Calificación del producto">
            {%- for i in (1..5) -%}
              <svg class="pm-star{% if i <= section.settings.star_count %} pm-star--filled{% endif %}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            {%- endfor -%}
            {%- if section.settings.review_count > 0 -%}
              <span class="product-main__review-count">({{ section.settings.review_count }} reviews)</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment %} Precio {%- endcomment %}
        <div class="product-main__price" id="pm-price-{{ section.id }}">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <s class="product-main__price--compare">{{ current_variant.compare_at_price | money }}</s>
            <span class="product-main__price--sale">{{ current_variant.price | money }}</span>
            <span class="product-main__price-badge">
              -{{ current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price }}%
            </span>
          {%- else -%}
            <span class="product-main__price--current">{{ current_variant.price | money }}</span>
          {%- endif -%}
        </div>

        {%- comment %} Descripción corta {%- endcomment %}
        {%- if section.settings.show_description and product.description != blank -%}
          <div class="product-main__description">{{ product.description }}</div>
        {%- endif -%}

        {%- comment %} Divisor {%- endcomment %}
        <div class="product-main__divider"></div>

        {%- comment %} ── FORMULARIO DE VARIANTES ── {%- endcomment %}
        {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}

          <input type="hidden" name="id" id="pm-variant-id-{{ section.id }}" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" id="pm-qty-hidden-{{ section.id }}" value="1">

          {%- comment %} Opciones de variante {%- endcomment %}
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              {%- liquid
                # IMPORTANTE: capturar el índice de la opción ANTES de entrar a loops anidados.
                # Si se usa forloop.parentloop.index0 dentro de un for anidado dos niveles,
                # apunta al loop intermedio, no al loop de opciones — ese era el bug.
                assign option_index = forloop.index0
                assign option_name_lower = option.name | downcase
                assign is_color = false
                if option_name_lower == 'color' or option_name_lower == 'colour' or option_name_lower == 'colores'
                  assign is_color = true
                endif
                assign current_value_for_option = current_variant.options[option_index]
              -%}

              <div class="product-main__option" data-option-index="{{ option_index }}">

                <div class="product-main__option-header">
                  <span class="product-main__option-name">
                    {{ option.name }}:
                  </span>
                  {%- if is_color -%}
                    <span class="product-main__option-selected" id="pm-selected-{{ section.id }}-{{ option_index }}">
                      {{ current_value_for_option }}
                    </span>
                  {%- endif -%}
                </div>

                {%- if is_color -%}
                  {%- comment %} SWATCHES de color {%- endcomment %}
                  <div class="product-main__swatches" role="radiogroup" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign is_selected = false
                        if current_value_for_option == value
                          assign is_selected = true
                        endif

                        # Chequear disponibilidad usando option_index capturado arriba (no forloop.parentloop).
                        assign variant_available = false
                        for variant in product.variants
                          if variant.options[option_index] == value and variant.available
                            assign variant_available = true
                            break
                          endif
                        endfor

                        assign color_val = value | downcase | replace: ' ', '-'
                        assign colorHexa = shop.metaobjects['shopify--color-pattern'][color_val]
                      -%}
                      <label
                        class="product-main__swatch{% if is_selected %} is-selected{% endif %}{% unless variant_available %} is-unavailable{% endunless %}"
                        title="{{ value }}"
                        data-option-index="{{ option_index }}"
                        data-value="{{ value }}"
                        data-pm-swatch="{{ section.id }}"
                        style="--swatch-color: {{ value | downcase }};"
                      >
                        <input
                          type="radio"
                          name="option-{{ option_index }}"
                          value="{{ value | escape }}"
                          {% if is_selected %}checked{% endif %}
                          class="product-main__swatch-input"
                          aria-label="{{ value }}"
                        >
                        
                        <span class="product-main__swatch-inner" style="background-color: {{colorHexa.color}};"></span>
                        {%- unless variant_available -%}
                          <span class="product-main__swatch-x" aria-hidden="true"></span>
                        {%- endunless -%}
                      </label>
                    {%- endfor -%}
                  </div>

                {%- else -%}
                  {%- comment %} PILLS para tallas y otras opciones {%- endcomment %}
                  <div class="product-main__pills" role="radiogroup" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign is_selected = false
                        if current_value_for_option == value
                          assign is_selected = true
                        endif

                        # Chequear disponibilidad usando option_index capturado arriba (no forloop.parentloop).
                        assign variant_available = false
                        for variant in product.variants
                          if variant.options[option_index] == value and variant.available
                            assign variant_available = true
                            break
                          endif
                        endfor
                      -%}
                      <label
                        class="product-main__pill{% if is_selected %} is-selected{% endif %}{% unless variant_available %} is-unavailable{% endunless %}"
                        data-option-index="{{ option_index }}"
                        data-value="{{ value }}"
                        data-pm-pill="{{ section.id }}"
                      >
                        <input
                          type="radio"
                          name="option-{{ option_index }}"
                          value="{{ value | escape }}"
                          {% if is_selected %}checked{% endif %}
                          class="product-main__pill-input"
                          aria-label="{{ value }}"
                        >
                        {{ value }}
                      </label>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

              </div>
            {%- endfor -%}
          {%- endunless -%}
          {%- comment %} ── CANTIDAD + AGREGAR AL CARRITO ── {%- endcomment %}
          <div class="product-main__purchase-row">

            {%- comment %} Selector de cantidad {%- endcomment %}
            <div class="product-main__qty">
              <button
                class="product-main__qty-btn"
                type="button"
                data-pm-qty-minus="{{ section.id }}"
                aria-label="Reducir cantidad"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="10" x2="16" y2="10"/></svg>
              </button>
              <output
                class="product-main__qty-value"
                id="pm-qty-display-{{ section.id }}"
                aria-live="polite"
                aria-label="Cantidad"
              >1</output>
              <button
                class="product-main__qty-btn"
                type="button"
                data-pm-qty-plus="{{ section.id }}"
                aria-label="Aumentar cantidad"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="10" y1="4" x2="10" y2="16"/><line x1="4" y1="10" x2="16" y2="10"/></svg>
              </button>
            </div>

            {%- comment %} Botón agregar al carrito {%- endcomment %}
            <button
              type="submit"
              name="add"
              class="product-main__add-btn"
              id="pm-add-btn-{{ section.id }}"
              data-pm-add="{{ section.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span id="pm-add-label-{{ section.id }}">
                {%- if current_variant.available -%}
                  {{ section.settings.add_to_cart_label | default: 'AGREGAR AL CARRITO' }}
                {%- else -%}
                  {{ section.settings.sold_out_label | default: 'AGOTADO' }}
                {%- endif -%}
              </span>
              <span class="product-main__add-spinner" id="pm-spinner-{{ section.id }}" aria-hidden="true">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="60" stroke-dashoffset="60"><animateTransform attributeName="transform" type="rotate" values="0 12 12;360 12 12" dur="0.8s" repeatCount="indefinite"/></circle></svg>
              </span>
            </button>

          </div>

          {%- comment %} Mensaje de error / éxito {%- endcomment %}
          <p class="product-main__cart-msg" id="pm-cart-msg-{{ section.id }}" aria-live="polite"></p>

        {%- endform -%}

        {%- comment %} Divisor {%- endcomment %}
        <div class="product-main__divider"></div>

        {%- comment %} ── TRUST BADGES ── {%- endcomment %}
        {%- if section.blocks.size > 0 -%}
          <div class="product-main__badges">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_badge' -%}
                <div class="product-main__badge" {{ block.shopify_attributes }}>
                  <div class="product-main__badge-icon" aria-hidden="true">
                    {%- case block.settings.icon -%}
                      {%- when 'truck' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      {%- when 'return' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.48"/></svg>
                      {%- when 'support' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.8 19.8 0 0 1 11.6 18a19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 3.82 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-.89a2 2 0 0 1 2.11-.45c.9.34 1.84.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                      {%- when 'shield' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- when 'leaf' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 19.11L2 21h10c6 0 10-4 10-10V3c-4 2-7 3-5 5z"/><path d="M9.5 14.5L3.82 19.11"/></svg>
                      {%- when 'gift' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                      {%- when 'Quality' -%}
                        <svg xmlns="http://www.w3.org/2000/svg"  viewBox="0 0 29 32" fill="none"><path d="M3.87399 6.75342L1.47399 4.65342C1.13356 4.33922 0.898412 3.9276 0.800661 3.47477C0.702909 3.02193 0.747319 2.54996 0.927825 2.12331C1.10833 1.69666 1.41613 1.33613 1.8092 1.09095C2.20227 0.845765 2.66143 0.727891 3.12399 0.75342H22.624C23.056 0.758587 23.4775 0.888044 23.8379 1.12632C24.1983 1.3646 24.4825 1.70161 24.6565 2.0971C24.8306 2.49258 24.887 2.92981 24.8192 3.35652C24.7513 3.78324 24.5621 4.1814 24.274 4.50342L21.874 6.75342M3.87399 6.75342H21.874M3.87399 6.75342V24.7534H21.874V6.75342M3.87399 14.2534L18.874 6.75342" stroke="#1F1F1F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M27.874 21.7539V17.2539C27.874 15.6626 27.2418 14.1365 26.1166 13.0113C24.9914 11.886 23.4653 11.2539 21.874 11.2539L3.87397 20.2539M6.87397 24.7539L21.874 17.2539M21.874 24.7539L24.274 26.8539C24.6 27.1621 24.8228 27.5637 24.9117 28.0034C25.0007 28.4432 24.9514 28.8998 24.7707 29.3105C24.59 29.7211 24.2867 30.0659 23.9024 30.2975C23.518 30.529 23.0715 30.6361 22.624 30.6039H3.12397C2.69193 30.5987 2.27051 30.4693 1.91007 30.231C1.54964 29.9927 1.26543 29.6557 1.09142 29.2602C0.917408 28.8647 0.860947 28.4275 0.928785 28.0008C0.996624 27.5741 1.18589 27.1759 1.47397 26.8539L3.87397 24.7539" stroke="#1F1F1F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- when 'Shipping' -%}
