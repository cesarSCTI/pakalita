{% comment %}
  Section: Gallery Carousel
  - Carrusel con botones prev/next
  - Desktop: N columnas configurables con navegación
  - Tablet: 2 columnas con navegación
  - Móvil: 1 card completa con navegación
{% endcomment %}

{%- assign section_cols_desktop = section.settings.columns_desktop -%}

<section
  class="gc"
  id="gc-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-cols-desktop="{{ section_cols_desktop }}"
  data-cols-tablet="2"
  data-cols-mobile="1"
  style="
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="gc__wrap gc__wrap--{{ section.settings.layout_width }}">

    {%- if section.settings.section_title != blank -%}
      <div class="gc__header">
        <h2 class="gc__title">{{ section.settings.section_title }}</h2>
      </div>
    {%- endif -%}

    <div class="gc__stage">

      <button class="gc__btn gc__btn--prev" id="gc-prev-{{ section.id }}" aria-label="Anterior" type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="gc__viewport" id="gc-vp-{{ section.id }}">
        <div class="gc__track" id="gc-track-{{ section.id }}">
          {%- for block in section.blocks -%}
            <div class="gc__item" {{ block.shopify_attributes }}>
              <div class="gc__card">

                {%- if block.settings.item_image != blank -%}
                  <div class="gc__img-wrap">
                    {{
                      block.settings.item_image
                      | image_url: width: 600
                      | image_tag:
                        class: 'gc__img',
                        loading: 'lazy',
                        alt: block.settings.item_title | default: shop.name | escape
                    }}
                  </div>
                {%- else -%}
                  <div class="gc__placeholder">
                    <svg viewBox="0 0 400 400" aria-hidden="true">
                      <rect fill="#f2f2f2" width="400" height="400"/>
                      <text x="200" y="200" text-anchor="middle" dy=".3em" fill="#ccc" font-size="18">Sin imagen</text>
                    </svg>
                  </div>
                {%- endif -%}

                {%- if block.settings.item_title != blank or block.settings.item_description != blank -%}
                  <div class="gc__content">
                    {%- if block.settings.item_title != blank -%}
                      <h3 class="gc__item-title">{{ block.settings.item_title }}</h3>
                    {%- endif -%}
                    {%- if block.settings.item_description != blank -%}
                      <p class="gc__item-desc">{{ block.settings.item_description }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}

              </div>
            </div>
          {%- else -%}
            {%- for i in (1..3) -%}
              <div class="gc__item">
                <div class="gc__card">
                  <div class="gc__placeholder">
                    <svg viewBox="0 0 400 400" aria-hidden="true">
                      <rect fill="#f2f2f2" width="400" height="400"/>
                      <text x="200" y="200" text-anchor="middle" dy=".3em" fill="#ccc" font-size="18">Item {{ i }}</text>
                    </svg>
                  </div>
                  <div class="gc__content">
                    <h3 class="gc__item-title">Título {{ i }}</h3>
                    <p class="gc__item-desc">Descripción del item</p>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

      <button class="gc__btn gc__btn--next" id="gc-next-{{ section.id }}" aria-label="Siguiente" type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    <div class="gc__dots" id="gc-dots-{{ section.id }}" aria-hidden="true"></div>

  </div>
</section>

<style>

/* =====================================================
   SECTION
   ===================================================== */
.gc {
  width: 100%;
  box-sizing: border-box;
}

.gc__wrap {
  width: 100%;
  box-sizing: border-box;
  padding-left: {{ section.settings.padding_left }}px;
  padding-right: {{ section.settings.padding_right }}px;
}

.gc__wrap--container {
  max-width: 1360px;
  margin: 0 auto;
}

/* =====================================================
   HEADER
   ===================================================== */
.gc__header {
  text-align: center;
  margin-bottom: 2rem;
}

.gc__title {
  margin: 0;
  font-size: 2rem;
  font-weight: 500;
  color: #111;
  font-family: "Platypi", serif !important;
}

/* =====================================================
   STAGE — contiene botones + viewport
   ===================================================== */
.gc__stage {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

/* =====================================================
   BOTONES
   ===================================================== */
.gc__btn {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1.5px solid #111;
  background: transparent;
  color: #111;
  cursor: pointer;
  opacity: 0.5;
  transition: opacity 0.2s ease, background 0.2s ease;
  padding: 0;
}

.gc__btn:hover { opacity: 1; background: rgba(0,0,0,0.05); }
.gc__btn:disabled { opacity: 0.15; cursor: default; }

/* =====================================================
   VIEWPORT — recorta el track
   ===================================================== */
.gc__viewport {
  flex: 1 1 0%;
  overflow: hidden;
  width: 100%;
}

/* =====================================================
   TRACK
   ===================================================== */
.gc__track {
  display: flex;
  gap: {{ section.settings.gap }}px;
  transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
  align-items: stretch;
}

/* =====================================================
   ITEM — ancho calculado en JS, pero base CSS:
   Desktop usa variable --gc-cols
   ===================================================== */
.gc__item {
  flex: 0 0 calc(
    (100% - ({{ section_cols_desktop }} - 1) * {{ section.settings.gap }}px)
    / {{ section_cols_desktop }}
  );
  box-sizing: border-box;
  min-width: 0;
}

@media (max-width: 900px) {
  .gc__item {
    flex: 0 0 calc((100% - {{ section.settings.gap }}px) / 2);
  }
}

@media (max-width: 600px) {
  .gc__item {
    flex: 0 0 100%;
  }

  .gc__title {
    font-size: 1.5rem;
  }

  .gc__btn {
    width: 36px;
    height: 36px;
  }
}

/* =====================================================
   CARD
   ===================================================== */
.gc__card {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #fff;
  border-radius: 0.5rem;
  overflow: hidden;
}

/* =====================================================
   IMAGEN
   ===================================================== */
.gc__img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  background: #f5f5f5;
  flex-shrink: 0;
}

.gc__img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.4s ease;
}

.gc__card:hover .gc__img {
  transform: scale(1.04);
}

/* =====================================================
   PLACEHOLDER
   ===================================================== */
.gc__placeholder {
  width: 100%;
  aspect-ratio: 1;
  background: #f2f2f2;
  border: 1px dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.gc__placeholder svg {
  width: 100%;
  height: 100%;
  opacity: 0.4;
}

/* =====================================================
   CONTENIDO
   ===================================================== */
.gc__content {
  padding: 1.25rem;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.gc__item-title {
  margin: 0 0 0.5rem;
  font-size: 1.1rem;
  font-weight: 400;
  color: #111;
  line-height: 1.3;
  font-family: "Platypi", serif !important;
  font-style: italic;
}

.gc__item-desc {
  margin: 0;
  font-size: 0.95rem;
  color: #666;
  line-height: 1.5;
  font-family: "Poppins", sans-serif !important;
}

/* =====================================================
   DOTS
   ===================================================== */
.gc__dots {
  display: flex;
  justify-content: center;
  gap: 6px;
  margin-top: 1.25rem;
}

.gc__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #111;
  opacity: 0.2;
  transition: opacity 0.2s ease, transform 0.2s ease;
  cursor: pointer;
  border: none;
  padding: 0;
}

.gc__dot--active {
  opacity: 0.85;
  transform: scale(1.25);
}

/* =====================================================
   REDUCED MOTION
   ===================================================== */
@media (prefers-reduced-motion: reduce) {
  .gc__track { transition: none; }
  .gc__img   { transition: none; }
}

</style>

<script>
(function () {
  'use strict';

  function initGalleryCarousel(section) {
    const id      = section.dataset.sectionId;
    const track   = document.getElementById('gc-track-' + id);
    const vp      = document.getElementById('gc-vp-' + id);
    const btnPrev = document.getElementById('gc-prev-' + id);
    const btnNext = document.getElementById('gc-next-' + id);
    const dotsWrap= document.getElementById('gc-dots-' + id);

    if (!track || !vp) return;

    const colsDesktop = parseInt(section.dataset.colsDesktop) || 3;
    const colsTablet  = parseInt(section.dataset.colsTablet)  || 2;
    const colsMobile  = parseInt(section.dataset.colsMobile)  || 1;

    let currentIndex = 0;

    /* ---- helpers ---- */
    function getCols() {
      const w = vp.offsetWidth;
      if (w <= 600) return colsMobile;
      if (w <= 900) return colsTablet;
      return colsDesktop;
    }

    function getItems() {
      return Array.from(track.querySelectorAll('.gc__item'));
    }

    function getGap() {
      return parseFloat(getComputedStyle(track).gap) || 0;
    }

    function getItemWidth() {
      const items = getItems();
      if (!items.length) return 0;
      return items[0].offsetWidth + getGap();
    }

    function maxIndex() {
      return Math.max(0, getItems().length - getCols());
    }

    /* ---- resize items ---- */
    function resizeItems() {
      const cols = getCols();
      const gap  = getGap();
      const vpW  = vp.offsetWidth;
      const itemW = (vpW - gap * (cols - 1)) / cols;
      getItems().forEach(function (item) {
        item.style.flex = '0 0 ' + itemW + 'px';
      });
    }

    /* ---- dots ---- */
    function buildDots() {
      if (!dotsWrap) return;
      const pages = maxIndex() + 1;
      dotsWrap.innerHTML = '';
      if (pages <= 1) return;
      for (let i = 0; i < pages; i++) {
        const dot = document.createElement('button');
        dot.className = 'gc__dot' + (i === 0 ? ' gc__dot--active' : '');
        dot.setAttribute('aria-label', 'Página ' + (i + 1));
        dot.dataset.index = i;
        dot.addEventListener('click', function () { goTo(parseInt(this.dataset.index)); });
        dotsWrap.appendChild(dot);
      }
    }

    function updateDots() {
      if (!dotsWrap) return;
      const dots = dotsWrap.querySelectorAll('.gc__dot');
      dots.forEach(function (dot, i) {
        dot.classList.toggle('gc__dot--active', i === currentIndex);
      });
    }

    /* ---- navigate ---- */
    function goTo(index) {
      currentIndex = Math.max(0, Math.min(index, maxIndex()));
      const offset = currentIndex * getItemWidth();
      track.style.transform = 'translateX(-' + offset + 'px)';
      btnPrev.disabled = currentIndex === 0;
      btnNext.disabled = currentIndex >= maxIndex();
      updateDots();
    }

    /* ---- init ---- */
    function setup() {
      resizeItems();
      buildDots();
      goTo(0);
    }

    btnPrev.addEventListener('click', function () { goTo(currentIndex - 1); });
    btnNext.addEventListener('click', function () { goTo(currentIndex + 1); });

    /* Swipe táctil */
    var touchStartX = 0;
    vp.addEventListener('touchstart', function (e) {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    vp.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) goTo(currentIndex + (dx < 0 ? 1 : -1));
    }, { passive: true });

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        resizeItems();
        buildDots();
        goTo(Math.min(currentIndex, maxIndex()));
      }, 120);
    });

    setup();
  }

  function init() {
    document.querySelectorAll('.gc').forEach(function (section) {
      initGalleryCarousel(section);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', function (e) {
      var s = e.target.querySelector('.gc');
      if (s) initGalleryCarousel(s);
    });
  }
})();
</script>

{% schema %}
{
  "name": "V2 Gallery Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Título de la sección (opcional)",
      "default": "Galería"
    },
    {
      "type": "select",
      "id": "layout_width",
      "label": "Ancho del contenedor",
      "default": "container",
      "options": [
        { "value": "container", "label": "Ancho contenedor" },
        { "value": "full",      "label": "Ancho completo" }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columnas visibles — Desktop (>900px)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre cards",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding izquierdo",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding derecho",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "gallery_item",
      "name": "Item de galería",
      "settings": [
        {
          "type": "image_picker",
          "id": "item_image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "item_title",
          "label": "Título",
          "default": "Título del item"
        },
        {
          "type": "textarea",
          "id": "item_description",
          "label": "Descripción",
          "default": "Descripción del item de galería"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "V2 Gallery Carousel",
      "category": "Custom",
      "blocks": [
        { "type": "gallery_item", "settings": { "item_title": "Arte Zapoteca", "item_description": "Tejidos que narran historia" } },
        { "type": "gallery_item", "settings": { "item_title": "Arte Mixteca",  "item_description": "Tradición en cada hilo" } },
        { "type": "gallery_item", "settings": { "item_title": "Arte Huichol",  "item_description": "Historias que se crean" } }
      ]
    }
  ]
}
{% endschema %}
