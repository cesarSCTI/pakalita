{% comment %}
  Section: Gallery Carousel
  - Carrusel con bloques reutilizables
  - Cada item: imagen + descriptivos
  - Flexbox responsivo
  - Control de ancho (full/container), paddings, cantidad de slides visibles
{% endcomment %}

<section
  class="gallery-carousel"
  id="gallery-carousel-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
  "
>
  <div class="gallery-carousel__wrapper gallery-carousel__wrapper--{{ section.settings.layout_width }}">

    {% if section.settings.section_title != blank %}
      <div class="gallery-carousel__header">
        <h2 class="gallery-carousel__title">{{ section.settings.section_title }}</h2>
      </div>
    {% endif %}

    <div class="gallery-carousel__container">
      <div 
        class="gallery-carousel__viewport"
        style="--carousel-columns: {{ section.settings.columns_desktop }};"
      >
        {% for block in section.blocks %}
          <div 
            class="gallery-carousel__item"
            {{ block.shopify_attributes }}
            style="--item-width: calc(100% / var(--carousel-columns));"
          >
            <div class="gallery-carousel__card">
              
              {% if block.settings.item_image != blank %}
                <div class="gallery-carousel__image-wrap">
                  {{ block.settings.item_image | image_url: width: 600 | image_tag: 
                    class: 'gallery-carousel__image',
                    alt: block.settings.item_title | default: shop.name | escape
                  }}
                </div>
              {% else %}
                <div class="gallery-carousel__placeholder">
                  <svg class="placeholder-svg" viewBox="0 0 400 400">
                    <rect fill="#f2f2f2" width="400" height="400"/>
                    <text x="200" y="200" text-anchor="middle" dy=".3em" fill="#ccc" font-size="18">
                      Imagen no seleccionada
                    </text>
                  </svg>
                </div>
              {% endif %}

              {% if block.settings.item_title != blank or block.settings.item_description != blank %}
                <div class="gallery-carousel__content">
                  {% if block.settings.item_title != blank %}
                    <h3 class="gallery-carousel__item-title">{{ block.settings.item_title }}</h3>
                  {% endif %}
                  {% if block.settings.item_description != blank %}
                    <p class="gallery-carousel__item-description">{{ block.settings.item_description }}</p>
                  {% endif %}
                </div>
              {% endif %}

            </div>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

{% style %}

.gallery-carousel {
  width: 100%;
  box-sizing: border-box;
}

.gallery-carousel__wrapper {
  width: 100%;
  box-sizing: border-box;
}

.gallery-carousel__wrapper--full {
  max-width: 100%;
}

.gallery-carousel__wrapper--container {
  max-width: 1360px;
  margin: 0 auto;
  padding: 0 1rem;
}

.gallery-carousel__header {
  text-align: center;
  margin-bottom: 2rem;
}

.gallery-carousel__title {
  margin: 0;
  font-size: 2rem;
  font-weight: 500;
  color: #111;
}

.gallery-carousel__container {
  width: 100%;
  overflow: hidden;
}

.gallery-carousel__viewport {
  display: flex;
  gap: 1.5rem;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-behavior: smooth;
  scroll-snap-type: x mandatory;
  padding: 0.5rem 0;
  margin: -0.5rem 0;
  justify-content:center;
}

/* Deshabilitar scroll en desktop cuando hay múltiples columnas */
@media (min-width: 769px) {
  .gallery-carousel__viewport {
    overflow-x: visible;
    flex-wrap: nowrap;
  }
}

.gallery-carousel__item {
  min-width: 250px;
  scroll-snap-align: start;
  box-sizing: border-box;
  flex:1;
}

@media (max-width: 768px) {
  .gallery-carousel__item {
    flex: 0 0 85%;
    min-width: 250px;
  }
}

@media (max-width: 480px) {
  .gallery-carousel__item {
    flex: 0 0 95%;
    min-width: 200px;
  }
}

.gallery-carousel__card {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #fff;
  border-radius: 0.5rem;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.gallery-carousel__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

.gallery-carousel__image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  background: #f5f5f5;
  flex-shrink: 0;
}

.gallery-carousel__image {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.4s ease;
}

.gallery-carousel__card:hover .gallery-carousel__image {
  transform: scale(1.05);
}

.gallery-carousel__placeholder {
  width: 100%;
  aspect-ratio: 1;
  background: #f2f2f2;
  border: 1px dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
  box-sizing: border-box;
}

.gallery-carousel__placeholder .placeholder-svg {
  width: 100%;
  height: 100%;
  opacity: 0.4;
}

.gallery-carousel__content {
  padding: 1.25rem;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align:center;
  font-family: "Poppins", sans-serif !important;
}

.gallery-carousel__item-title {
  margin: 0 0 0.5rem;
  font-size: 1.1rem;
  font-weight: 600;
  color: #111;
  line-height: 1.3;
}

.gallery-carousel__item-description {
  margin: 0;
  font-size: 0.95rem;
  color: #666;
  line-height: 1.5;
}

/* Responsive columns */
@media (max-width: 1024px) {
  .gallery-carousel__viewport {
    --carousel-columns: 2;
  }
  
  .gallery-carousel__item {
    --item-width: calc(100% / 2);
  }
}

@media (max-width: 768px) {
  .gallery-carousel__title {
    font-size: 1.5rem;
  }
  
  .gallery-carousel__viewport {
    --carousel-columns: 1;
    gap: 1rem;
  }

  .gallery-carousel__item {
    --item-width: 100%;
  }
}

{% endstyle %}

{% schema %}
{
  "name": "V2 Gallery Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Título de la sección (opcional)",
      "default": "Galería"
    },
    {
      "type": "select",
      "id": "layout_width",
      "label": "Ancho del contenedor",
      "default": "container",
      "options": [
        {"value": "container", "label": "Ancho contenedor"},
        {"value": "full", "label": "Ancho completo"}
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Cantidad de columnas (Desktop)",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding izquierdo",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding derecho",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "gallery_item",
      "name": "Item de galería",
      "settings": [
        {
          "type": "image_picker",
          "id": "item_image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "item_title",
          "label": "Título",
          "default": "Título del item"
        },
        {
          "type": "textarea",
          "id": "item_description",
          "label": "Descripción",
          "default": "Descripción del item de galería"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "V2 Gallery Carousel",
      "category": "Custom",
      "blocks": [
        {
          "type": "gallery_item",
          "settings": {
            "item_title": "Arte Zapoteca",
            "item_description": "Tejidos que narran historia"
          }
        },
        {
          "type": "gallery_item",
          "settings": {
            "item_title": "Arte Mixteca",
            "item_description": "Tradición en cada hilo"
          }
        },
        {
          "type": "gallery_item",
          "settings": {
            "item_title": "Arte Huichol",
            "item_description": "Historias que se crean"
          }
        }
      ]
    }
  ]
}
{% endschema %}
