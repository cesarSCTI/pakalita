{% comment %}
  Section: Featured Collection
  Carrusel con Flexbox — desktop y móvil
  Sin grid. Transform-based carousel + dots + flechas
{% endcomment %}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign show_view_all = section.settings.show_view_all
  assign view_all_label = section.settings.view_all_label | default: 'Ver todos'
  assign add_to_cart_label = section.settings.add_to_cart_label | default: 'Agregar al carrito'
-%}

<section
  class="featured-collection-section"
  id="featured-collection-{{ section.id }}"
  style="
    --fc-columns: {{ columns_desktop }};
    --fc-gap: {{ section.settings.gap }}px;
    --fc-radius: {{ section.settings.card_radius }}px;
    --fc-btn-bg: {{ section.settings.btn_bg_color }};
    --fc-btn-text: {{ section.settings.btn_text_color }};
    --fc-btn-radius: {{ section.settings.btn_radius }}px;
    --fc-add-bg: {{ section.settings.add_bg_color }};
    --fc-add-text: {{ section.settings.add_text_color }};
    --fc-add-radius: {{ section.settings.add_radius }}px;
    --fc-nav-color: {{ section.settings.nav_color }};
    --fc-section-bg: {{ section.settings.section_bg }};
    --fc-title-color: {{ section.settings.title_color }};
    --fc-padding-top: {{ section.settings.padding_top }}px;
    --fc-padding-bottom: {{ section.settings.padding_bottom }}px;
    --fc-card-bg: {{ section.settings.card_bg }};
    --fc-price-color: {{ section.settings.price_color }};
    --fc-product-title-color: {{ section.settings.product_title_color }};
  "
>
  <div class="featured-collection__inner page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="featured-collection__heading">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- comment %} Viewport: oculta el overflow del track {%- endcomment %}
    <div class="featured-collection__viewport" id="fc-viewport-{{ section.id }}">
      <div
        class="featured-collection__track"
        id="fc-track-{{ section.id }}"
        role="list"
      >
        {%- if collection != blank -%}
          {%- for product in collection.products limit: products_to_show -%}
            <div class="featured-collection__card" role="listitem">
              <div class="fc-card__image-wrap">
                <a href="{{ product.url }}" class="fc-card__image-link" tabindex="-1" aria-hidden="true">
                  {%- if product.featured_media -%}
                    {{
                      product.featured_media
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        widths: '400, 600, 800',
                        sizes: '(max-width: 600px) 80vw, 30vw',
                        class: 'fc-card__image',
                        alt: product.title
                    }}
                    {%- if product.media[1] -%}
                      {{
                        product.media[1]
                        | image_url: width: 800
                        | image_tag:
                          loading: 'lazy',
                          widths: '400, 600, 800',
                          sizes: '(max-width: 600px) 80vw, 30vw',
                          class: 'fc-card__image fc-card__image--hover',
                          alt: product.title
                      }}
                    {%- endif -%}
                  {%- else -%}
                    <div class="fc-card__placeholder">
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </a>

                {%- if section.settings.show_wishlist -%}
                  <button class="fc-card__wishlist" aria-label="Guardar {{ product.title }}" type="button" data-wishlist="{{ product.id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  </button>
                {%- endif -%}

                {%- if product.compare_at_price > product.price -%}
                  <span class="fc-card__badge fc-card__badge--sale">
                    {{- 'products.product.on_sale' | t | default: 'Sale' -}}
                  </span>
                {%- endif -%}

                {%- if section.settings.show_add_to_cart -%}
                  {%- if product.variants.size == 1 and product.variants.first.available -%}
                    <form action="/cart/add" method="post" class="fc-card__add-form">
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="fc-card__add-btn">{{ add_to_cart_label }}</button>
                    </form>
                  {%- else -%}
                    <a href="{{ product.url }}" class="fc-card__add-btn fc-card__add-btn--link">
                      {{section.settings.add_to_cart_label_options}}
                    </a>
                  {%- endif -%}
                {%- endif -%}
              </div>

              <div class="fc-card__info">
                <a href="{{ product.url }}" class="fc-card__title-link">
                  <h3 class="fc-card__title">{{ product.title |  truncate: 25}}</h3>
                </a>
                <div class="fc-card__price">
                  {%- if product.compare_at_price > product.price -%}
                    <s class="fc-card__price--compare">{{ product.compare_at_price | money }}</s>
                    <span class="fc-card__price--sale">{{ product.price | money }}</span>
                  {%- else -%}
                    <span>{{ product.price | money }}</span>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- else -%}
            {%- for i in (1..columns_desktop) -%}
              <div class="featured-collection__card">
                <div class="fc-card__image-wrap">
                  <div class="fc-card__placeholder">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
                </div>
                <div class="fc-card__info">
                  <h3 class="fc-card__title">Producto 0{{ i }}</h3>
                  <div class="fc-card__price"><span>$0.00</span></div>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..columns_desktop) -%}
            <div class="featured-collection__card">
              <div class="fc-card__image-wrap">
                <div class="fc-card__placeholder">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
              </div>
              <div class="fc-card__info">
                <h3 class="fc-card__title">Producto 0{{ i }}</h3>
                <div class="fc-card__price"><span>$0.00</span></div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment %} Controles: flechas + dots en la misma fila {%- endcomment %}
    <div class="featured-collection__controls">
      <button
        class="featured-collection__arrow featured-collection__arrow--prev"
        aria-label="Anterior"
        type="button"
        data-carousel-prev="{{ section.id }}"
        disabled
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="featured-collection__dots" id="fc-dots-{{ section.id }}" aria-hidden="true"></div>

      <button
        class="featured-collection__arrow featured-collection__arrow--next"
        aria-label="Siguiente"
        type="button"
        data-carousel-next="{{ section.id }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    {%- if show_view_all and collection != blank -%}
      <div class="featured-collection__footer">
        <a href="{{ collection.url }}" class="featured-collection__view-all">{{ view_all_label }}</a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}

/* =====================================================
   SECTION
   ===================================================== */
.featured-collection-section {
  background: var(--fc-section-bg);
  padding-top: var(--fc-padding-top);
  padding-bottom: var(--fc-padding-bottom);
}

.featured-collection__heading {
  text-align: center;
  font-style: italic;
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  color: var(--fc-title-color);
  margin: 0 0 1.75rem;
}

/* =====================================================
   VIEWPORT — recorta lo que sale del carrusel
   ===================================================== */
.featured-collection__viewport {
  overflow: hidden;
  width: 100%;
  padding: 0px var(--padding-container);
  max-width:var(--container-v2);
  margin: auto;
}

/* =====================================================
   TRACK — Flex puro, sin grid
   El JS mueve con transform translateX
   ===================================================== */
.featured-collection__track {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--fc-gap);
  will-change: transform;
  transition: transform 0.42s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  /*
  
  */
}

/* =====================================================
   CARD
   flex-basis = (viewport - gaps_entre_visibles) / columnas
   ===================================================== */
.featured-collection__card {
  flex: 0 0 calc(
    (100% - (var(--fc-columns) - 1) * var(--fc-gap)) / var(--fc-columns)
  );
  min-width: 0;
  background: var(--fc-card-bg);
  border-radius: var(--fc-radius);
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  transition: box-shadow 0.3s ease;
}

.featured-collection__card:hover {
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

/* =====================================================
   IMAGEN
   ===================================================== */
.fc-card__image-wrap {
  position: relative;
  overflow: hidden;
  background: #f5f3f0;
  aspect-ratio: 1 / 1;
}

.fc-card__image-link {
  display: block;
  width: 100%;
  height: 100%;
}

.fc-card__image {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: opacity 0.4s ease;
}

.fc-card__image--hover {
  position: absolute;
  inset: 0;
  opacity: 0;
}

.fc-card__image-link:hover .fc-card__image:not(.fc-card__image--hover) { opacity: 0; }
.fc-card__image-link:hover .fc-card__image--hover { opacity: 1; }

.fc-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0ece6;
}

.fc-card__placeholder .placeholder-svg {
  width: 55%;
  height: 55%;
  opacity: 0.3;
}

/* =====================================================
   WISHLIST
   ===================================================== */
.fc-card__wishlist {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 1px 6px rgba(0,0,0,0.12);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  z-index: 2;
  padding: 0;
}

.fc-card__wishlist:hover { transform: scale(1.12); box-shadow: 0 3px 10px rgba(0,0,0,0.18); }
.fc-card__wishlist.is-active svg { fill: #c0392b; color: #c0392b; stroke: #c0392b; }
.fc-card__wishlist svg { width: 16px; height: 16px; color: #333; }

/* =====================================================
   BADGE
   ===================================================== */
.fc-card__badge {
  position: absolute;
  top: 10px;
  left: 10px;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 4px;
  z-index: 2;
  line-height: 1.4;
}

.fc-card__badge--sale { background: #c0392b; color: #fff; }

/* =====================================================
   ADD TO CART
   ===================================================== */
.fc-card__add-form,
.fc-card__add-btn--link {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 3;
}

.fc-card__add-btn {
  display: block;
  width: 90%;
  margin:auto;
  padding: 0.75rem 1rem;
  background: var(--fc-add-bg);
  color: var(--fc-add-text);
  border: none;
  cursor: pointer;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-align: center;
  text-decoration: none;
  line-height: 1;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.fc-card__add-btn--link {
  display: block;
  padding: 0.75rem 1rem;
  background: var(--fc-add-bg);
  color: var(--fc-add-text);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-align: center;
  text-decoration: none;
  line-height: 1;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  font-family: Poppins, sans-serif !important;
}

.fc-card__image-wrap:hover .fc-card__add-btn,
.fc-card__image-wrap:hover .fc-card__add-btn--link {
  transform: translateY(-20px);
}

/* =====================================================
   INFO
   ===================================================== */
.fc-card__info {
  padding: 20px;
  border: solid 1px #ececec;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.fc-card__title-link { text-decoration: none; color: inherit; }

.fc-card__title {
  font-size: 0.9rem;
  font-weight: 600;
  margin: 0 0 0.3rem;
  color: var(--fc-product-title-color);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.fc-card__price {
  font-size: 0.9rem;
  color: var(--fc-price-color);
  display: flex;
  gap: 0.5rem;
  align-items: baseline;
}

.fc-card__price--compare { color: #999; font-weight: 400; }
.fc-card__price--sale    { color: #c0392b; font-weight: 600; }

/* =====================================================
   CONTROLES — flex row centrado
   ===================================================== */
.featured-collection__controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-top: 1.4rem;
}

.featured-collection__arrow {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #fff;
  border: 1px solid #e0ddd8;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--fc-nav-color);
  padding: 0;
  transition: box-shadow 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
}

.featured-collection__arrow svg { width: 16px; height: 16px; }

.featured-collection__arrow:hover:not(:disabled) {
  box-shadow: 0 4px 16px rgba(0,0,0,0.14);
  transform: scale(1.07);
}

.featured-collection__arrow:disabled {
  opacity: 0.28;
  cursor: default;
}

/* ---- Dots ---- */
.featured-collection__dots {
  display: flex;
  align-items: center;
  gap: 6px;
}

.featured-collection__dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #d0cdc9;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  flex-shrink: 0;
}

.featured-collection__dot.is-active {
  background: var(--fc-nav-color);
  transform: scale(1.35);
}

/* =====================================================
   VER TODOS
   ===================================================== */
.featured-collection__footer {
  display: flex;
  justify-content: center;
  margin-top: 2rem;
}

.featured-collection__view-all {
  display: inline-block;
  padding: 0.7em 2.2em;
  background: var(--fc-btn-bg);
  color: var(--fc-btn-text);
  border-radius: var(--fc-btn-radius);
  text-decoration: none;
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.featured-collection__view-all:hover {
  opacity: 0.85;
  transform: translateY(-1px);
}
h3.fc-card__title {
    font-family: "Poppins", sans-serif;
    font-size: 20px;
}
/* =====================================================
   MÓVIL — card más ancha
   ===================================================== */
@media screen and (max-width: 600px) {
  .featured-collection__card {
    flex: 0 0 78vw;
    max-width: 300px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .featured-collection__track { transition: none; }
  .fc-card__add-btn,
  .fc-card__add-btn--link,
  .fc-card__image { transition: none; }
}

{% endstylesheet %}

<script>
(function () {
  const sid      = '{{ section.id }}';
  const viewport = document.getElementById('fc-viewport-' + sid);
  const track    = document.getElementById('fc-track-' + sid);
  const dotsWrap = document.getElementById('fc-dots-' + sid);
  const btnPrev  = document.querySelector('[data-carousel-prev="' + sid + '"]');
  const btnNext  = document.querySelector('[data-carousel-next="' + sid + '"]');

  if (!track || !viewport) return;

  const cards = Array.from(track.children);
  let current = 0;

  /* ─── Cuántas cards son visibles según CSS variable ─── */
  function visibleCount() {
    const cols = parseInt(
      getComputedStyle(track.closest('.featured-collection-section'))
        .getPropertyValue('--fc-columns')
    ) || 3;
    return window.innerWidth <= 600 ? 1 : cols;
  }

  function totalPages() {
    return Math.max(1, Math.ceil(cards.length / visibleCount()));
  }

  /* ─── Mover el track con transform ─── */
  function goTo(page) {
    const pages = totalPages();
    page = Math.max(0, Math.min(page, pages - 1));
    current = page;

    const cols  = visibleCount();
    const gap   = parseFloat(getComputedStyle(track).gap) || 0;
    const cardW = cards[0] ? cards[0].offsetWidth : 0;
    const offset = page * cols * (cardW + gap);

    track.style.transform = 'translateX(-' + offset + 'px)';

    if (btnPrev) btnPrev.disabled = current === 0;
    if (btnNext) btnNext.disabled = current >= pages - 1;

    dotsWrap.querySelectorAll('.featured-collection__dot')
      .forEach((d, i) => d.classList.toggle('is-active', i === current));
  }

  /* ─── Construir dots ─── */
  function buildDots() {
    dotsWrap.innerHTML = '';
    const pages = totalPages();
    if (pages <= 1) return;
    for (let i = 0; i < pages; i++) {
      const dot = document.createElement('button');
      dot.className = 'featured-collection__dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('aria-label', 'Página ' + (i + 1));
      dot.addEventListener('click', () => goTo(i));
      dotsWrap.appendChild(dot);
    }
  }

  /* ─── Swipe táctil ─── */
  let touchStartX = 0;
  viewport.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  viewport.addEventListener('touchend', e => {
    const delta = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(delta) > 40) goTo(delta > 0 ? current + 1 : current - 1);
  }, { passive: true });

  /* ─── Botones ─── */
  if (btnPrev) btnPrev.addEventListener('click', () => goTo(current - 1));
  if (btnNext) btnNext.addEventListener('click', () => goTo(current + 1));

  /* ─── Wishlist ─── */
  document.querySelectorAll('[data-wishlist]').forEach(btn => {
    btn.addEventListener('click', () => btn.classList.toggle('is-active'));
  });

  /* ─── Init / Resize ─── */
  function init() {
    current = 0;
    track.style.transform = 'translateX(0)';
    buildDots();
    if (btnPrev) btnPrev.disabled = true;
    if (btnNext) btnNext.disabled = totalPages() <= 1;
  }

  init();

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(init, 120);
  });

})();
</script>

{% schema %}
{
  "name": "V2 Featured Collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Productos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección a mostrar"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 24,
      "step": 1,
      "label": "Número de productos a mostrar",
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Cards visibles a la vez (desktop)",
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Espacio entre tarjetas",
      "default": 16
    },
    {
      "type": "header",
      "content": "Tarjeta de producto"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fondo de la tarjeta",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Redondez de esquinas",
      "default": 12
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Color del título",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Color del precio",
      "default": "#111111"
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Mostrar botón de wishlist",
      "default": true
    },
    {
      "type": "header",
      "content": "Botón Agregar al carrito"
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Mostrar 'Agregar al carrito'",
      "default": true
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Texto del botón",
      "default": "AGREGAR AL CARRITO"
    },
    {
      "type": "text",
      "id": "add_to_cart_label_options",
      "label": "Texto del botón con opciones en producto",
      "default": "VER TODAS LAS OPCIONES"
    },
    {
      "type": "color",
      "id": "add_bg_color",
      "label": "Fondo del botón",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
