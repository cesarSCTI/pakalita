{% comment %}
  Section: Flex Text + Image
  - Layout flexbox 2 columnas
  - Control de tag h1..h6, color, grosor y descripción
  - Imagen selectable
{% endcomment %}

<section 
  class="flex-text-image-section flex-text-image-section--{{ section.settings.layout_width }}" 
  id="flex-text-image-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    background-image: {% if section.settings.bg_image %}url('{{ section.settings.bg_image | image_url }}'){% endif %};
    background-size: cover;
    background-position: center;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
    --image-border-radius: {{ section.settings.image_border_radius }}px;
  "
>
  <div class="flex-text-image__wrapper">
    <div class="flex-text-image__inner" style="flex-direction: 
  {%if section.settings.image_side == 'left' %}
  row-reverse
  {% else %}
  row
  {% endif %}
  ; 
   align-items: {{ section.settings.align_vertical }};">

    <div class="flex-text-image__content">
      {% if section.settings.title != blank %}
        <{{ section.settings.title_tag }}
          class="flex-text-image__title"
          style="color: {{ section.settings.title_color }}; font-weight: {{ section.settings.title_weight }};font-family: 'Poppins';"
        >
          {{ section.settings.title }}
        </{{ section.settings.title_tag }}>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="flex-text-image__description" style="color: {{ section.settings.description_color }};">{{ section.settings.description }}</div>
      {% endif %}
    </div>

    <div class="flex-text-image__media" style="--image-aspect-ratio: {{ section.settings.image_aspect_ratio }}; ">
      {% if section.settings.image != blank %}
        <div class="flex-text-image__image-wrapper">
          {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'flex-text-image__img', alt: section.settings.image.alt | default: section.settings.title | escape }}
        </div>
      {% else %}
        <div class="flex-text-image__placeholder">Imagen no seleccionada</div>
      {% endif %}
    </div>

    </div>
  </div>
</section>

{% style %}
.flex-text-image-section {
  width: 100%;
  box-sizing: border-box;
  border-radius: var(--image-border-radius, 8px);
  font-family: "Poppins", sans-serif !important; 
}

.flex-text-image__wrapper {
  width: 100%;
  box-sizing: border-box;
}

.flex-text-image-section--full .flex-text-image__wrapper {
  max-width: 100%;
}

.flex-text-image-section--container .flex-text-image__wrapper {
  max-width: 1360px;
  margin: 0 auto;
}

.flex-text-image__inner {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
  justify-content: space-between;
}

.flex-text-image__content,
.flex-text-image__media {
  flex: 1 1 300px;
  min-width: 280px;
}

.flex-text-image__content{
  padding:40px;
}

.flex-text-image__title {
  margin: 0 0 20px;
  line-height: 1.1;
  font-size:{{ section.settings.font_size_Desktop }}px;
}

.flex-text-image__description {
  margin: 0;
  line-height: 1.5;
  color: #333;
  font-size:18px;
}

.flex-text-image__image-wrapper {
  width: 100%;
  aspect-ratio: var(--image-aspect-ratio, auto);
  overflow: hidden;
  border-radius: var(--image-border-radius, 8px);
}

.flex-text-image__img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.flex-text-image__placeholder {
  width: 100%;
  aspect-ratio: var(--image-aspect-ratio, 1);
  background: #f2f2f2;
  border: 1px dashed #ccc;
  border-radius: 0.5rem;
  padding: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  box-sizing: border-box;
}

@media (max-width: 768px) {
  .flex-text-image__inner {
    flex-direction: column;
  }
  .flex-text-image__title {
    margin: 0 0 20px;
    line-height: 1.1;
    font-size:{{ section.settings.font_size_Mobile }}px;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "V2 Flex Text + Image",
  "tag": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Título"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Etiqueta de título",
      "default": "h2",
      "options": [
        {"value": "h1", "label": "H1"},
        {"value": "h2", "label": "H2"},
        {"value": "h3", "label": "H3"},
        {"value": "h4", "label": "H4"},
        {"value": "h5", "label": "H5"},
        {"value": "h6", "label": "H6"}
      ]
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Grosor del título",
      "default": "700",
      "options": [
        {"value": "300", "label": "Ligero (300)"},
        {"value": "400", "label": "Normal (400)"},
        {"value": "500", "label": "Medio (500)"},
        {"value": "600", "label": "Semi-bold (600)"},
        {"value": "700", "label": "Bold (700)"},
        {"value": "800", "label": "Extra-bold (800)"}
      ]
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color de la descripción",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "font_size_Desktop",
      "label": "Font size desktop",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "range",
      "id": "font_size_Mobile",
      "label": "Font size mobile",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descripción"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "select",
      "id": "image_side",
      "label": "Posición de la imagen",
      "default": "right",
      "options": [
        {"value": "right", "label": "Derecha"},
        {"value": "left", "label": "Izquierda"}
      ]
    },
    {
      "type": "select",
      "id": "align_vertical",
      "label": "Alineación vertical",
      "default": "center",
      "options": [
        {"value": "flex-start", "label": "Arriba"},
        {"value": "center", "label": "Centro"},
        {"value": "flex-end", "label": "Abajo"}
      ]
    },
    {
      "type": "select",
      "id": "layout_width",
      "label": "Ancho del contenedor",
      "default": "container",
      "options": [
        {"value": "container", "label": "Ancho contenedor"},
        {"value": "full", "label": "Ancho completo"}
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagen de fondo (opcional)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding izquierdo",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding derecho",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Relación de aspecto de la imagen",
      "default": "auto",
      "options": [
        {"value": "auto", "label": "Automático"},
        {"value": "1", "label": "1:1 (Cuadrado)"},
        {"value": "4/3", "label": "4:3"},
        {"value": "16/9", "label": "16:9"},
        {"value": "3/2", "label": "3:2"},
        {"value": "2/1", "label": "2:1"}
      ]
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius de la imagen",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "V2 Flex Text + Image",
      "category": "Custom"
    }
  ]
}
{% endschema %}
